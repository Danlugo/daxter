# .NET build outputs (scoped so the top-level bin/daxter wrapper stays tracked)
src/**/bin/
src/**/obj/
tests/**/bin/
tests/**/obj/
# Top-level CI build artifacts (tarballs etc.). Anchored at the repo root so it doesn't
# silently swallow src/Daxter.Core/Artifacts/ — the artifact-store namespace folder.
/artifacts/
*.tar.gz

# Secrets — never commit
.env
*.env
!.env.example

# IDE / OS
.vs/
.vscode/
.idea/
*.user
.DS_Store

# Local Claude skills / UI contract — kept local, never shipped to the public repo
.claude/
extension/*.mcpb
