@inherits LayoutComponentBase
@implements IDisposable
@inject VersionService Version
@inject UsageStore Usage
@inject JobService Jobs
@inject NavigationManager Nav
@inject QueryHistoryStore Hist
@inject ExploreActions Actions

<header class="topbar">
    <span class="brand">DAXter <small>Console @Version.Current</small></span>
    <nav>
        <NavLink href="" Match="NavLinkMatch.All">Status</NavLink>
        <NavLink href="explore">Explore</NavLink>
        <NavLink href="refresh">Refresh</NavLink>
        <NavLink href="configure">Configure</NavLink>
        <NavLink href="jobs">@(Jobs.ActiveCount > 0 ? $"Jobs ({Jobs.ActiveCount})" : "Jobs")</NavLink>
        <NavLink href="logs">Logs</NavLink>
    </nav>
</header>

<div class="shell">
    <aside class="sidebar">
        <div class="side-title">Frequent@(context is null ? "" : context == UsageStore.RefreshContext ? " · Refresh" : " · Explore")</div>

        @if (context is null)
        {
            <p class="side-empty">Open <a href="explore">Explore</a> or <a href="refresh">Refresh</a> — each page keeps its own most-used shortcuts.</p>
        }
        else if (wsTop.Count == 0 && dsTop.Count == 0 && tblTop.Count == 0)
        {
            <p class="side-empty">Your most-used workspaces, datasets, and tables for this page show up here as you use it.</p>
        }

        @if (wsTop.Count > 0)
        {
            <div class="side-group">
                <div class="side-h">Workspaces</div>
                @foreach (var w in wsTop)
                {
                    <a class="side-item" href="@WsLink(w)" title="@w.Name">
                        <span class="side-name">@w.Name</span><span class="side-count">@w.Count</span>
                    </a>
                }
            </div>
        }

        @if (dsTop.Count > 0)
        {
            <div class="side-group">
                <div class="side-h">Datasets</div>
                @foreach (var d in dsTop)
                {
                    <a class="side-item" href="@DsLink(d)" title="@($"{d.Name} — in workspace “{d.Parent}”")">
                        <span class="side-name"><span class="nm">@d.Name</span><small class="side-sub">@d.Parent</small></span>
                        <span class="side-count">@d.Count</span>
                    </a>
                }
            </div>
        }

        @if (tblTop.Count > 0)
        {
            <div class="side-group">
                <div class="side-h">Tables</div>
                @foreach (var t in tblTop)
                {
                    <a class="side-item" href="@TblLink(t)" title="@TblTitle(t)">
                        <span class="side-name"><span class="nm">@t.Name</span><small class="side-sub">@TblDs(t)</small></span>
                        <span class="side-count">@t.Count</span>
                    </a>
                }
            </div>
        }

        @if (context == UsageStore.ExploreContext && recent.Count > 0)
        {
            <div class="side-group">
                <div class="side-h">Recent queries <button class="link" @onclick="ClearQueries">clear</button></div>
                @foreach (var h in recent)
                {
                    <div class="side-recent">
                        <button class="side-qrun" @onclick="() => RunQuery(h)" title="@h.Dax — click to run">
                            <span class="nm">@QPreview(h.Dax)</span>
                            <small class="side-sub">@(string.IsNullOrEmpty(h.Dataset) ? h.Workspace : h.Dataset) · @(h.Count)×</small>
                        </button>
                        <button class="side-qdel" @onclick="() => RemoveQuery(h)" title="Remove">×</button>
                    </div>
                }
            </div>
        }
    </aside>

    <main class="content">
        @Body
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private const char Sep = '\u001F'; // table Parent = workspace<unit-sep>dataset

    private IReadOnlyList<UsageItem> wsTop = Array.Empty<UsageItem>();
    private IReadOnlyList<UsageItem> dsTop = Array.Empty<UsageItem>();
    private IReadOnlyList<UsageItem> tblTop = Array.Empty<UsageItem>();
    private IReadOnlyList<QueryEntry> recent = Array.Empty<QueryEntry>();
    private string? context;

    protected override void OnInitialized()
    {
        Usage.Changed += OnUsageChanged;
        Jobs.Changed += OnUsageChanged;          // refresh the Jobs nav count
        Hist.Changed += OnUsageChanged;          // refresh Recent queries
        Nav.LocationChanged += OnLocationChanged; // sidebar is per-page
        Reload();
    }

    private Task RunQuery(QueryEntry h) => Actions.Run(h);
    private void RemoveQuery(QueryEntry h) { Hist.Remove(h.Dax, h.Workspace, h.Dataset); recent = Hist.Recent(8); }
    private void ClearQueries() { Hist.Clear(); recent = Hist.Recent(8); }

    private static string QPreview(string dax)
    {
        var oneLine = string.Join(' ', dax.Split('\n', '\r', '\t').Select(s => s.Trim()).Where(s => s.Length > 0));
        return oneLine.Length > 42 ? oneLine[..42] + "…" : oneLine;
    }

    // The Frequent list is page-scoped: Explore and Refresh each keep their own.
    private string? ContextFor(string uri)
    {
        var path = Nav.ToBaseRelativePath(uri).Split('?', '#')[0].Trim('/').ToLowerInvariant();
        return path switch
        {
            "explore" => UsageStore.ExploreContext,
            "refresh" => UsageStore.RefreshContext,
            _ => null,
        };
    }

    private void Reload()
    {
        context = ContextFor(Nav.Uri);
        if (context is null)
        {
            wsTop = dsTop = tblTop = Array.Empty<UsageItem>();
            return;
        }
        wsTop = Usage.Top(UsageStore.Workspace, 6, context);
        dsTop = Usage.Top(UsageStore.Dataset, 6, context);
        tblTop = Usage.Top(UsageStore.Table, 6, context);
        recent = context == UsageStore.ExploreContext ? Hist.Recent(8) : Array.Empty<QueryEntry>();
    }

    private void OnUsageChanged() => InvokeAsync(() => { Reload(); StateHasChanged(); });
    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
        => InvokeAsync(() => { Reload(); StateHasChanged(); });

    private string LinkBase => context ?? UsageStore.ExploreContext;

    private string WsLink(UsageItem w)
        => $"{LinkBase}?ws={Uri.EscapeDataString(w.Name)}";

    private string DsLink(UsageItem d)
        => $"{LinkBase}?ws={Uri.EscapeDataString(d.Parent ?? "")}&ds={Uri.EscapeDataString(d.Name)}";

    private string TblLink(UsageItem t)
        => $"{LinkBase}?ws={Uri.EscapeDataString(TblWs(t))}&ds={Uri.EscapeDataString(TblDs(t))}&table={Uri.EscapeDataString(t.Name)}";

    // A table's Parent is "workspace<sep>dataset" — different models often reuse table names,
    // so the dataset (and workspace) is what disambiguates them.
    private static string TblWs(UsageItem t) { var p = (t.Parent ?? "").Split(Sep); return p.Length > 0 ? p[0] : ""; }
    private static string TblDs(UsageItem t) { var p = (t.Parent ?? "").Split(Sep); return p.Length > 1 ? p[1] : ""; }
    private static string TblTitle(UsageItem t) => $"{t.Name} — in dataset “{TblDs(t)}” (workspace “{TblWs(t)}”)";

    public void Dispose()
    {
        Usage.Changed -= OnUsageChanged;
        Jobs.Changed -= OnUsageChanged;
        Hist.Changed -= OnUsageChanged;
        Nav.LocationChanged -= OnLocationChanged;
    }
}
