@page "/sql"
@using Daxter.Core.Auth
@inject DaxterUi Ui
@inject UsageStore Usage
@inject IJSRuntime JS
@inject UiBusy BusyState
@inject NavigationManager Nav

<PageTitle>DAXter — SQL</PageTitle>

<h1>SQL</h1>
<p class="muted">Run T-SQL against a Fabric Warehouse or Lakehouse SQL endpoint. Reads anytime; writes need the <strong>Allow writes</strong> gate.</p>

<div class="dax-tools">
    <button class="btn-sm back-btn" @onclick="GoBack" title="Back to the previous page">← Back</button>
</div>

<div class="row">
    <div>
        <label>Workspace <span class="muted">(@workspaces.Count — type to search)</span></label>
        <SearchableSelect Items="workspaces" @bind-Value="workspace" OnChange="OnWorkspaceChanged"
                          Placeholder="type to search a workspace…" Disabled="@busy" />
        <button class="btn-sm" @onclick="LoadWorkspaces" disabled="@busy">Load</button>
    </div>
    <div>
        <label>SQL endpoint <span class="muted">(@endpoints.Count)</span></label>
        <SearchableSelect Options="endpointOptions" @bind-Value="endpoint" OnChange="OnEndpointPicked"
                          Placeholder="type to search a warehouse or lakehouse…"
                          Disabled="@(busy || string.IsNullOrEmpty(workspace))" />
        @if (!string.IsNullOrEmpty(endpoint) && SelectedEndpoint() is { } ep)
        {
            <small class="muted">@ep.Kind · server: <code>@ep.Server</code> · database: <code>@ep.Database</code></small>
        }
    </div>
</div>

@if (NeedsSqlSignIn(error) || NeedsSqlSignIn(objError))
{
    <div class="card" style="border-color:var(--warn); margin:.6rem 0;">
        <strong>One-time SQL sign-in required.</strong>
        <p class="muted" style="margin:.2rem 0 .4rem;">
            Microsoft locks the Power BI client id out of <code>database.windows.net</code> at the AAD level (AADSTS65002),
            so DAXter signs in to Fabric SQL endpoints with a separate (pre-authorized) client id. Your Power BI sign-in
            still covers XMLA / REST — this is only for the SQL surface.
        </p>
        <button class="btn" @onclick="StartSqlLogin" disabled="@sqlLoginBusy">🔐 Sign in for Fabric SQL</button>
    </div>
}

@if (sqlDevice is not null)
{
    <div class="modal-overlay" @onclick="CancelSqlLogin">
        <div class="modal" @onclick:stopPropagation="true">
            <h3>Sign in for Fabric SQL</h3>
            <p>Open the URL below and enter the code:</p>
            <p>
                <a href="@sqlDevice.VerificationUrl" target="_blank" rel="noopener">@sqlDevice.VerificationUrl</a>
                · code <code>@sqlDevice.UserCode</code>
            </p>
            <p class="muted">@sqlLoginStatus</p>
            <div class="cmd-group">
                <button class="btn-sm" @onclick="CancelSqlLogin">Close</button>
            </div>
        </div>
    </div>
}

<ErrorBanner Message="@error" />

<div class="dax-layout">
    @if (showObjects)
    {
        <aside class="dax-objects">
            <div class="pane-head">
                <span class="side-title">Objects</span>
                <button class="pane-x" @onclick="() => showObjects = false" title="Hide objects">×</button>
            </div>
            @if (!HasEndpoint)
            {
                <p class="side-empty">Pick a SQL endpoint to browse its schemas, tables, views, functions, and stored procedures.</p>
            }
            else if (objError is not null)
            {
                <p class="bad-text">@objError</p>
                <button class="btn-sm" @onclick="LoadObjects">Retry</button>
            }
            else if (objLoading || objects is null)
            {
                <p class="muted">Loading objects…</p>
            }
            else if (objects.Count == 0)
            {
                <p class="side-empty">No objects found in this endpoint.</p>
            }
            else
            {
                <input class="obj-search" @bind="objSearch" @bind:event="oninput" placeholder="filter objects…" autocomplete="off" />
                <div class="obj-tree">
                    @foreach (var schema in FilteredSchemas())
                    {
                        <div class="obj-table">
                            <button class="obj-tname" @onclick="() => ToggleSchema(schema.Name)" title="@schema.Name">
                                <span class="chev">@(IsSchemaExpanded(schema.Name) ? "▾" : "▸")</span>
                                <span>@schema.Name</span>
                                <small class="muted" style="margin-left:auto;">@schema.Total</small>
                            </button>
                            @if (IsSchemaExpanded(schema.Name))
                            {
                                @foreach (var grp in schema.Groups)
                                {
                                    var groupKey = $"{schema.Name}/{grp.Kind}";
                                    <button class="obj-tname" @onclick="() => ToggleGroup(groupKey)" title="@grp.Kind"
                                            style="padding-left:1rem;">
                                        <span class="chev">@(IsGroupExpanded(groupKey) ? "▾" : "▸")</span>
                                        <span>@KindLabel(grp.Kind)</span>
                                        <small class="muted" style="margin-left:auto;">@grp.Items.Count</small>
                                    </button>
                                    @if (IsGroupExpanded(groupKey))
                                    {
                                        @foreach (var item in FilteredItems(grp.Items))
                                        {
                                            <button class="obj-item" style="padding-left:2.4rem;"
                                                    @onclick="() => InsertObject(schema.Name, item)"
                                                    title="Click to insert [@schema.Name].[@item]">
                                                <span class="obj-icon">@KindIcon(grp.Kind)</span>@item
                                            </button>
                                        }
                                    }
                                }
                            }
                        </div>
                    }
                </div>
            }
        </aside>
    }

    <div class="dax-main">
        <div class="dax-tools">
            @if (!showObjects) { <button class="btn-sm" @onclick="() => showObjects = true" title="Show objects">▸ Objects</button> }
            <button class="btn" @onclick="AskRunOrRun" disabled="@(!HasEndpoint || string.IsNullOrWhiteSpace(sql) || busy)">▶ Run SQL</button>
            <span class="export-group">
                <button class="btn-sm" @onclick="ExportAllAsync" disabled="@(!HasEndpoint || string.IsNullOrWhiteSpace(sql) || busy)"
                        title="Stream the FULL result set straight to a .csv download — bypasses the in-browser grid, so SELECT * on a huge table is OK.">
                    ⬇ Export All CSV
                </button>
                <label class="inline export-opt" title="Wrap every field in quotes (matches Power BI / Excel “Export data” style).">
                    <input type="checkbox" @bind="exportQuoteAll" /> Quote-all
                </label>
                <label class="inline export-opt" title="End lines with CRLF (Windows / Excel) instead of LF.">
                    <input type="checkbox" @bind="exportCrlf" /> CRLF
                </label>
            </span>
            <button class="btn-sm" @onclick="() => sql = string.Empty" disabled="@(string.IsNullOrEmpty(sql) || busy)">Clear</button>
            <span class="muted dax-hint">
                Tip: click an object on the left to insert it · Ctrl+Enter runs · read-only by default.
                @if (!Ui.WritesEnabled) { <span> · <strong>Writes off</strong> — read queries only.</span> }
            </span>
        </div>

        @* Hidden form the "Export All CSV" button submits — POST to /api/sql/export triggers a
           streaming browser download. Outside the @code block so it can be submitted from JS. *@
        <form id="sql-export-form" method="post" action="/api/sql/export" style="display:none;" target="_blank">
            <input type="hidden" name="workspace" value="@workspace" />
            <input type="hidden" name="endpoint" value="@endpoint" />
            <input type="hidden" name="sql" value="@sql" />
            @* Endpoint reads "on" as the truthy value (HTML-form convention) — only render when on. *@
            @if (exportQuoteAll) { <input type="hidden" name="quoteAll" value="on" /> }
            @if (exportCrlf) { <input type="hidden" name="crlf" value="on" /> }
        </form>

        <div class="sql-edit">
            <textarea class="dax-editor" @bind="sql" @bind:event="oninput" rows="14"
                      placeholder="SELECT TOP 10 * FROM information_schema.tables ORDER BY table_name"
                      spellcheck="false" @onkeydown="OnEditorKey"></textarea>
        </div>

        @if (busy) { <p class="muted">Running…</p> }
        <ResultGrid Result="result" Error="@error" Empty="Pick a SQL endpoint, type a SELECT and Run." />
    </div>
</div>

@if (pendingWrite is not null)
{
    <div class="modal-overlay" @onclick="() => pendingWrite = null">
        <div class="modal" @onclick:stopPropagation="true">
            <h3>Confirm SQL write</h3>
            <p>This statement looks like a write. It will execute on:</p>
            <p><strong>@SelectedEndpoint()?.Name</strong> <span class="muted">(@SelectedEndpoint()?.Kind)</span>
               <br /><small class="muted">server: <code>@SelectedEndpoint()?.Server</code> · database: <code>@SelectedEndpoint()?.Database</code></small></p>
            <pre class="code">@pendingWrite</pre>
            <p class="muted">This writes to the Fabric SQL endpoint above.</p>
            <div class="cmd-group">
                <button class="btn-sm" @onclick="() => pendingWrite = null">Cancel</button>
                <button class="btn" @onclick="ConfirmRunWrite">✓ Confirm — run</button>
            </div>
        </div>
    </div>
}

@code {
    private List<string> workspaces = new();
    private List<FabricSqlClientEndpoint> endpoints = new();
    private string workspace = "", endpoint = "", sql = "";
    private QueryResult? result;
    private string? error;
    private bool busy;
    private string? pendingWrite;

    // ---- Export All format toggles (Web only — CLI/MCP have flags) ----
    // Defaults match the Run-SQL grid's CSV: RFC 4180 / LF.
    private bool exportQuoteAll;
    private bool exportCrlf;

    // ---- SQL-scope device-code sign-in (separate from Power BI's) ----
    private DeviceLogin? sqlDevice;
    private string sqlLoginStatus = "Waiting for sign-in…";
    private bool sqlLoginBusy;

    /// <summary>True when an error string surfaced from a SQL call looks like the AAD pre-authorization
    /// issue or the "Not signed in to Fabric SQL endpoints" guard — i.e. when the user needs to run the
    /// SQL-scope device-code flow once. Pure check on the message text.</summary>
    private static bool NeedsSqlSignIn(string? msg) =>
        !string.IsNullOrEmpty(msg) &&
        (msg.Contains("AADSTS65002", StringComparison.OrdinalIgnoreCase)
         || msg.Contains("Not signed in to Fabric SQL", StringComparison.OrdinalIgnoreCase)
         || msg.Contains("Fabric SQL authentication failed", StringComparison.OrdinalIgnoreCase));

    private async Task StartSqlLogin()
    {
        if (sqlLoginBusy) return;
        sqlLoginBusy = true; sqlLoginStatus = "Waiting for sign-in…";
        try
        {
            sqlDevice = await Ui.BeginSqlLoginAsync();
            if (sqlDevice.Completion.IsCompletedSuccessfully)
            {
                // Already signed in for SQL — close the modal and retry the last action.
                sqlDevice = null;
                error = null; objError = null;
                if (HasEndpoint) await LoadObjects();
                return;
            }
            // Await the background completion (token-cache write) and then retry the explorer load.
            _ = sqlDevice.Completion.ContinueWith(async t =>
            {
                await InvokeAsync(async () =>
                {
                    sqlLoginStatus = t.IsCompletedSuccessfully
                        ? "✓ Signed in — closing…"
                        : $"Sign-in failed: {t.Exception?.GetBaseException().Message}";
                    if (t.IsCompletedSuccessfully)
                    {
                        sqlDevice = null;
                        error = null; objError = null;
                        if (HasEndpoint) await LoadObjects();
                    }
                    StateHasChanged();
                });
            }, TaskScheduler.Default);
        }
        catch (Exception ex) { error = ex.Message; sqlDevice = null; }
        finally { sqlLoginBusy = false; StateHasChanged(); }
    }

    private void CancelSqlLogin() { sqlDevice = null; sqlLoginStatus = "Waiting for sign-in…"; }

    // ---- Objects explorer (left aside) ----
    private bool showObjects = true;
    private bool objLoading;
    private string? objError;
    private string? objectsFor;                            // endpoint name the current tree was loaded for
    private List<SchemaNode>? objects;                     // grouped (schema → kind → name)
    private readonly HashSet<string> expandedSchemas = new();
    private readonly HashSet<string> expandedGroups = new();
    private string objSearch = "";

    /// <summary>Grouped data shape feeding the tree.</summary>
    private sealed record KindGroup(string Kind, List<string> Items);
    private sealed record SchemaNode(string Name, List<KindGroup> Groups)
    {
        public int Total => Groups.Sum(g => g.Items.Count);
    }

    // Deep-link: /sql?ws=&ep=
    [Parameter, SupplyParameterFromQuery(Name = "ws")] public string? Qws { get; set; }
    [Parameter, SupplyParameterFromQuery(Name = "ep")] public string? Qep { get; set; }
    private string? appliedDeepLink;

    private bool HasEndpoint => !string.IsNullOrEmpty(endpoint) && !busy;

    /// <summary>Endpoint shape on the page — kept here (not in Core) so the bridge can keep returning
    /// a generic <see cref="QueryResult"/> like every other DAXter list. <c>Value</c> = endpoint name (the
    /// display label), which is also the deep-link parameter and the dictionary key into <see cref="endpoints"/>.</summary>
    private sealed record FabricSqlClientEndpoint(string Name, string Server, string Database, string Kind);

    // (value, label) pairs for SearchableSelect's Options mode — box shows the label, binds the name.
    private IReadOnlyList<(string Value, string Label)> endpointOptions =>
        endpoints.Select(e => (e.Name, $"{e.Name} ({e.Kind})")).ToList();

    private FabricSqlClientEndpoint? SelectedEndpoint() =>
        endpoints.FirstOrDefault(e => string.Equals(e.Name, endpoint, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        if (workspaces.Count == 0) await LoadWorkspaces();
    }

    /// <summary>Apply a deep-link (sql?ws=&ep=) — fires on initial nav AND on same-component navigation
    /// from the Frequent sidebar (clicking another SQL endpoint while already on /sql).</summary>
    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(Qws)) return;
        var key = $"{Qws}|{Qep}";
        if (key == appliedDeepLink) return;
        appliedDeepLink = key;

        BusyState.Begin();
        try
        {
            if (workspaces.Count == 0) await LoadWorkspaces();
            workspace = Qws!;
            await OnWorkspaceChanged();
            if (!string.IsNullOrEmpty(Qep))
            {
                endpoint = Qep!;
                Usage.Record(UsageStore.Dataset, endpoint, workspace, UsageStore.SqlContext);
                await LoadObjects();
            }
        }
        finally { BusyState.End(); StateHasChanged(); }
    }

    private async Task GoBack() => await JS.InvokeVoidAsync("history.back");

    private async Task LoadWorkspaces()
    {
        busy = true; BusyState.Begin(); error = null;
        try { workspaces = ColumnValues(await Ui.WorkspacesAsync(), "name"); }
        catch (Exception ex) { error = ex.Message; }
        finally { busy = false; BusyState.End(); }
    }

    private async Task OnWorkspaceChanged()
    {
        endpoints = new(); endpoint = ""; result = null;
        ResetObjects();
        if (string.IsNullOrEmpty(workspace)) return;
        busy = true; BusyState.Begin(); error = null;
        try
        {
            var r = await Ui.SqlEndpointsAsync(workspace);
            endpoints = r is null ? new() : r.Rows.Select(row => new FabricSqlClientEndpoint(
                row[0]?.ToString() ?? "",
                row[1]?.ToString() ?? "",
                row[2]?.ToString() ?? "",
                row[3]?.ToString() ?? "")).Where(e => !string.IsNullOrEmpty(e.Server)).ToList();
            Usage.Record(UsageStore.Workspace, workspace, null, UsageStore.SqlContext);
        }
        catch (Exception ex) { error = ex.Message; }
        finally { busy = false; BusyState.End(); }
    }

    private async Task OnEndpointPicked()
    {
        result = null;
        ResetObjects();
        if (string.IsNullOrEmpty(endpoint)) return;
        Usage.Record(UsageStore.Dataset, endpoint, workspace, UsageStore.SqlContext);
        await LoadObjects();
    }

    private void ResetObjects()
    {
        objects = null; objectsFor = null; objError = null;
        expandedSchemas.Clear(); expandedGroups.Clear();
    }

    /// <summary>Loads the schema/tables/views/funcs/procs tree for the currently picked endpoint.
    /// Single INFORMATION_SCHEMA UNION round-trip — see <see cref="FabricSqlClient.ListObjectsSql"/>.
    /// The result is grouped by (schema, kind) here so render is allocation-free.</summary>
    private async Task LoadObjects()
    {
        var ep = SelectedEndpoint();
        if (ep is null) return;
        objLoading = true; BusyState.Begin(); objError = null; objects = null; StateHasChanged();
        try
        {
            var r = await Ui.SqlObjectsAsync(ep.Server, ep.Database);
            objects = GroupObjects(r);
            objectsFor = endpoint;
            // Auto-expand the first schema (usually 'dbo') so the user sees something on landing.
            if (objects.Count > 0) expandedSchemas.Add(objects[0].Name);
        }
        catch (Exception ex) { objError = ex.Message; }
        finally { objLoading = false; BusyState.End(); StateHasChanged(); }
    }

    /// <summary>Folds a flat (schema, kind, name) result into schema → kind-group → items. Pure so it
    /// can be unit-tested without spinning up a Blazor host.</summary>
    private static List<SchemaNode> GroupObjects(QueryResult r)
    {
        // Column order is fixed by FabricSqlClient.ListObjectsSql: schema, kind, name.
        var bySchema = new Dictionary<string, Dictionary<string, List<string>>>(StringComparer.OrdinalIgnoreCase);
        foreach (var row in r.Rows)
        {
            var schema = row[0]?.ToString() ?? "";
            var kind = row[1]?.ToString() ?? "";
            var name = row[2]?.ToString() ?? "";
            if (schema.Length == 0 || name.Length == 0) continue;

            if (!bySchema.TryGetValue(schema, out var byKind))
                bySchema[schema] = byKind = new(StringComparer.OrdinalIgnoreCase);
            if (!byKind.TryGetValue(kind, out var items))
                byKind[kind] = items = new();
            items.Add(name);
        }

        // Stable kind order — matches Fabric's explorer (Tables, Views, Functions, Stored Procedures).
        var kindOrder = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase)
            { ["Table"] = 0, ["View"] = 1, ["Function"] = 2, ["Stored Procedure"] = 3 };

        return bySchema
            .OrderBy(kv => kv.Key, StringComparer.OrdinalIgnoreCase)
            .Select(kv => new SchemaNode(kv.Key,
                kv.Value
                    .OrderBy(kg => kindOrder.TryGetValue(kg.Key, out var o) ? o : int.MaxValue)
                    .ThenBy(kg => kg.Key, StringComparer.OrdinalIgnoreCase)
                    .Select(kg => new KindGroup(kg.Key, kg.Value)).ToList()))
            .ToList();
    }

    // ---- tree expand / filter / insert ----

    private bool IsSchemaExpanded(string s)
        => !string.IsNullOrEmpty(objSearch) || expandedSchemas.Contains(s);
    private bool IsGroupExpanded(string key)
        => !string.IsNullOrEmpty(objSearch) || expandedGroups.Contains(key);
    private void ToggleSchema(string s) { if (!expandedSchemas.Remove(s)) expandedSchemas.Add(s); }
    private void ToggleGroup(string key) { if (!expandedGroups.Remove(key)) expandedGroups.Add(key); }

    /// <summary>Schemas that have at least one item matching the search (or the schema name itself
    /// matches). Reuses the existing filter input pattern from the DAX Fields tree.</summary>
    private IEnumerable<SchemaNode> FilteredSchemas()
    {
        if (objects is null) yield break;
        var q = objSearch?.Trim();
        foreach (var s in objects)
        {
            if (string.IsNullOrEmpty(q)
                || s.Name.Contains(q, StringComparison.OrdinalIgnoreCase)
                || s.Groups.Any(g => g.Items.Any(i => i.Contains(q, StringComparison.OrdinalIgnoreCase))))
                yield return s;
        }
    }

    private IEnumerable<string> FilteredItems(List<string> items)
    {
        var q = objSearch?.Trim();
        return string.IsNullOrEmpty(q) ? items
            : items.Where(i => i.Contains(q, StringComparison.OrdinalIgnoreCase));
    }

    private static string KindLabel(string kind) => kind switch
    {
        "Table" => "Tables",
        "View" => "Views",
        "Function" => "Functions",
        "Stored Procedure" => "Stored Procedures",
        _ => kind,
    };

    // Single-char glyphs — match the DAX Fields tree style (⊞/▦/ƒ etc). Plain unicode so any font renders them.
    private static string KindIcon(string kind) => kind switch
    {
        "Table" => "▦",
        "View" => "▤",
        "Function" => "ƒ",
        "Stored Procedure" => "⚙",
        _ => "·",
    };

    /// <summary>Appends a bracketed <c>[schema].[name]</c> reference to the SQL editor, with a leading
    /// space if needed. Keeps cursor management cheap (no JS interop) — same approach as Query.razor.</summary>
    private void InsertObject(string schemaName, string objectName)
    {
        var qualified = $"[{schemaName}].[{objectName}]";
        var sep = string.IsNullOrEmpty(sql) || sql.EndsWith(" ") || sql.EndsWith("\n") ? "" : " ";
        sql = sql + sep + qualified;
    }

    /// <summary>If the SQL looks like a write and the gate is on, show the confirm-modal first;
    /// otherwise run directly. (Read-only goes straight through; writes with the gate off are blocked
    /// further down by Core's <see cref="Daxter.Core.Sql.SqlWriteGate"/> with a clear error.)</summary>
    private async Task AskRunOrRun()
    {
        if (string.IsNullOrWhiteSpace(sql) || !HasEndpoint) return;
        if (Ui.WritesEnabled && !Daxter.Core.Sql.SqlWriteGate.IsReadOnly(sql))
        {
            pendingWrite = sql;
            return;
        }
        await RunQuery();
    }

    private async Task ConfirmRunWrite()
    {
        pendingWrite = null;
        if (pendingWriteIsExport)
        {
            pendingWriteIsExport = false;
            await DoExportAsync();
        }
        else
        {
            await RunQuery();
        }
    }

    /// <summary>Triggers the streaming CSV export by submitting the hidden form on the page. The
    /// /api/sql/export endpoint resolves the workspace + endpoint name and streams the result-set
    /// CSV straight to the browser as a download — never going through the Blazor SignalR circuit,
    /// so SELECT * on a million-row table is OK. The form's values are bound to the same workspace /
    /// endpoint / sql state the editor uses, so what you Run is what you Export.</summary>
    private async Task ExportAllAsync()
    {
        if (!HasEndpoint || string.IsNullOrWhiteSpace(sql)) return;
        // Best-effort write-gate echo (the endpoint enforces it too) — show the confirm modal first
        // so the user doesn't kick off a 10-minute MERGE export by accident.
        if (Ui.WritesEnabled && !Daxter.Core.Sql.SqlWriteGate.IsReadOnly(sql))
        {
            pendingWrite = sql;
            pendingWriteIsExport = true;
            return;
        }
        await DoExportAsync();
    }

    private async Task DoExportAsync()
    {
        try
        {
            // Submit the hidden form. target="_blank" means a transient tab is opened to receive the
            // download — the tab closes itself when the browser saves the .csv. (We can't use
            // window.location because that would unload the /sql page mid-edit.)
            await JS.InvokeVoidAsync("eval", "document.getElementById('sql-export-form').submit();");
        }
        catch (Exception ex) { error = ex.Message; }
    }

    private bool pendingWriteIsExport;

    private async Task RunQuery()
    {
        var ep = SelectedEndpoint();
        if (ep is null) { error = "Pick a SQL endpoint first."; return; }
        busy = true; BusyState.Begin(); error = null; result = null; StateHasChanged();
        try
        {
            result = await Ui.SqlQueryAsync(ep.Server, ep.Database, sql);
            Usage.Record(UsageStore.Dataset, endpoint, workspace, UsageStore.SqlContext);
        }
        catch (Exception ex) { error = ex.Message; }
        finally { busy = false; BusyState.End(); }
    }

    /// <summary>Ctrl+Enter (or Cmd+Enter on macOS) runs the query — matches the DAX editor convention.</summary>
    private async Task OnEditorKey(KeyboardEventArgs e)
    {
        if ((e.CtrlKey || e.MetaKey) && string.Equals(e.Key, "Enter", StringComparison.OrdinalIgnoreCase))
        {
            await AskRunOrRun();
        }
    }

    private static List<string> ColumnValues(QueryResult r, string column)
    {
        var idx = -1;
        for (var i = 0; i < r.Columns.Count; i++)
            if (string.Equals(r.Columns[i], column, StringComparison.OrdinalIgnoreCase)) { idx = i; break; }
        if (idx < 0) return new();
        return r.Rows.Select(row => row[idx]?.ToString() ?? "")
                     .Where(s => s.Length > 0).OrderBy(s => s).ToList();
    }
}
