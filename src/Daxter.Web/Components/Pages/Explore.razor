@page "/explore"
@inject DaxterUi Ui
@inject UsageStore Usage
@inject QueryHistoryStore History
@inject IJSRuntime JS
@using System.Text

<PageTitle>DAXter — Explore</PageTitle>

<h1>Explore</h1>
<p class="muted">Browse models and run commands — the CLI/MCP capabilities, graphically.</p>

<div class="row">
    <div>
        <label>Workspace <span class="muted">(@workspaces.Count — type to search)</span></label>
        <div class="combo-wrap">
            <input class="combo" list="ws-list" @bind="workspace" @bind:after="OnWorkspaceChanged"
                   placeholder="type to search…" autocomplete="off" onfocus="this.select()" />
            @if (!string.IsNullOrEmpty(workspace))
            {
                <button class="combo-clear" @onclick="ClearWorkspace" title="Clear — pick another workspace">×</button>
            }
        </div>
        <datalist id="ws-list">@foreach (var w in workspaces) { <option value="@w"></option> }</datalist>
        <button class="btn-sm" @onclick="LoadWorkspaces" disabled="@busy">Load</button>
    </div>
    <div>
        <label>Dataset <span class="muted">(@datasets.Count)</span></label>
        <div class="combo-wrap">
            <input class="combo" list="ds-list" @bind="dataset" @bind:after="OnDatasetPicked" placeholder="type to search…"
                   autocomplete="off" onfocus="this.select()" />
            @if (!string.IsNullOrEmpty(dataset))
            {
                <button class="combo-clear" @onclick="ClearDataset" title="Clear — pick another dataset">×</button>
            }
        </div>
        <datalist id="ds-list">@foreach (var d in datasets) { <option value="@d"></option> }</datalist>
    </div>
</div>

@if (!string.IsNullOrEmpty(defaultWorkspace))
{
    <p>
        <button class="link" @onclick="LoadDefault" disabled="@busy">
            ⤓ Load default: @defaultWorkspace@(string.IsNullOrEmpty(defaultDataset) ? "" : " / " + defaultDataset)
        </button>
    </p>
}

<div class="tabs">
    <button class="tab @(tab == Tab.Browse ? "active" : "")" @onclick="EnterBrowse">Browse</button>
    <button class="tab @(tab == Tab.Query ? "active" : "")" @onclick="ShowQueryTab">DAX query</button>
</div>

@if (tab == Tab.Query)
{
    <div class="dax-layout">
        @if (showFields)
        {
            <aside class="dax-objects">
                <div class="pane-head">
                    <span class="side-title">Fields</span>
                    <button class="pane-x" @onclick="() => showFields = false" title="Hide fields">×</button>
                </div>
                @if (string.IsNullOrEmpty(dataset))
                {
                    <p class="side-empty">Pick a dataset to browse its tables, columns and measures.</p>
                }
                else if (objError is not null)
                {
                    <p class="bad-text">@objError</p>
                    <button class="btn-sm" @onclick="LoadObjects">Retry</button>
                }
                else if (objLoading || objects is null)
                {
                    <p class="muted">Loading fields…</p>
                }
                else
                {
                    <input class="obj-search" @bind="objSearch" @bind:event="oninput" placeholder="filter fields…" autocomplete="off" />
                    <div class="obj-tree">
                        @foreach (var t in FilteredTables())
                        {
                            <div class="obj-table">
                                <button class="obj-tname" @onclick="() => ToggleTable(t.Table)" title="@t.Table — click to insert">
                                    <span class="chev">@(IsExpanded(t.Table) ? "▾" : "▸")</span>
                                    <span @onclick:stopPropagation="true" @onclick="() => InsertTable(t.Table)">@t.Table</span>
                                </button>
                                @if (IsExpanded(t.Table))
                                {
                                    @foreach (var o in FilteredItems(t))
                                    {
                                        <button class="obj-item @(o.IsMeasure ? "measure" : "column")"
                                                @onclick="() => InsertRef(t.Table, o)" title="Insert reference">
                                            <span class="obj-icon">@(o.IsMeasure ? "ƒ" : "▦")</span>@o.Name
                                        </button>
                                    }
                                }
                            </div>
                        }
                    </div>
                }
            </aside>
        }

        <div class="dax-main">
            <div class="dax-tools">
                @if (!showFields) { <button class="btn-sm" @onclick="() => showFields = true" title="Show fields">▸ Fields</button> }
                <button class="btn" @onclick="RunQuery" disabled="@(!HasDataset)">▶ Run DAX</button>
                <button class="btn-sm" @onclick="FormatQuery" disabled="@(string.IsNullOrWhiteSpace(dax))" title="Pretty-print the DAX">⌗ Format</button>
                <span class="muted dax-hint">Tip: click a field on the left to insert it.</span>
                @if (!showRecent) { <button class="btn-sm" @onclick="() => showRecent = true" title="Show recent queries">Recent ◂</button> }
            </div>
            <textarea class="dax-editor" @bind="dax" @bind:event="oninput" rows="7" @ref="editorRef"
                      placeholder="EVALUATE TOPN(10, 'Table')   ·   type to autocomplete fields &amp; DAX functions" spellcheck="false"></textarea>
            @if (DaxIssues() is { Count: > 0 } issues)
            {
                <div class="dax-issues">
                    @foreach (var iss in issues) { <div class="dax-issue">⚠ @iss</div> }
                </div>
            }
            @if (busy) { <p class="muted">Running…</p> }
            <ResultGrid Result="result" Error="@error" Empty="Pick a dataset and run a query." />
        </div>

        @if (showRecent)
        {
            <aside class="dax-recent">
                <div class="pane-head">
                    <span class="side-title">Recent queries</span>
                    <button class="pane-x" @onclick="() => showRecent = false" title="Hide recent">×</button>
                </div>
                @if (history.Count == 0)
                {
                    <p class="side-empty">Queries you run show up here.</p>
                }
                else
                {
                    <button class="link" @onclick="ClearHistory">clear all</button>
                    <ul class="hist-list">
                        @foreach (var h in history)
                        {
                            <li class="hist-item">
                                <button class="hist-run" @onclick="() => RunHistory(h)" title="@h.Dax — click to run">
                                    <span class="hist-dax">@Preview(h.Dax)</span>
                                    <span class="hist-ctx">@(string.IsNullOrEmpty(h.Dataset) ? h.Workspace : h.Dataset) · @(h.Count)×</span>
                                </button>
                                <button class="hist-del" @onclick="() => RemoveHistory(h)" title="Remove">×</button>
                            </li>
                        }
                    </ul>
                }
            </aside>
        }
    </div>
}
else
{
    <nav class="crumbs">
        <button class="btn-sm back-btn" @onclick="GoBack" disabled="@(!CanGoBack)" title="Back to the previous view">← Back</button>
        <button class="link" @onclick="BrowseRoot">Workspaces</button>
        @if (!string.IsNullOrEmpty(workspace))
        {
            <span>›</span><button class="link" @onclick="BrowseWorkspace">@workspace</button>
        }
        @if (!string.IsNullOrEmpty(dataset))
        {
            <span>›</span>
            @if (!string.IsNullOrEmpty(selTable) || !string.IsNullOrEmpty(selMeasure)) { <button class="link" @onclick="BrowseDataset">@dataset</button> }
            else { <span class="crumb-current">@dataset</span> }
        }
        @if (!string.IsNullOrEmpty(selTable))
        {
            <span>›</span><span class="crumb-current">@selTable</span>
        }
        else if (!string.IsNullOrEmpty(selMeasure))
        {
            <span>›</span><span class="crumb-current">[@selMeasure]</span>
        }
    </nav>

    @if (string.IsNullOrEmpty(workspace))
    {
        <ErrorBanner Message="@error" />
        <ClickableList Items="workspaces" OnSelect="SelectWorkspace"
                       Empty="@(busy ? "Loading…" : "No workspaces — click Load.")" />
    }
    else if (string.IsNullOrEmpty(dataset))
    {
        <div class="cmd-group">
            <button class="btn-sm @(wsView == WsView.Datasets ? "active" : "")" @onclick="BrowseDatasets">Datasets</button>
            <button class="btn-sm @(wsView == WsView.Reports ? "active" : "")" @onclick="ShowReports">Reports</button>
            <button class="btn-sm @(wsView == WsView.Lineage ? "active" : "")" @onclick="ShowLineage">Lineage</button>
        </div>
        @if (wsView == WsView.Datasets)
        {
            <ErrorBanner Message="@error" />
            <ClickableList Items="datasets" OnSelect="SelectDataset"
                           Empty="@(busy ? "Loading…" : "No datasets in this workspace.")" />
        }
        else
        {
            @if (busy) { <p class="muted">Running…</p> }
            <ResultGrid Result="result" Error="@error" />
        }
    }
    else if (!string.IsNullOrEmpty(selMeasure))
    {
        <div class="cmd-group">
            <button class="btn" @onclick="() => RunMeasure(selMeasure!)">Run measure →</button>
            <span class="muted">@selMeasure@(string.IsNullOrEmpty(MeasureField("DisplayFolder")) ? "" : " · " + MeasureField("DisplayFolder"))</span>
        </div>
        <div class="side-h">DAX definition</div>
        @if (string.IsNullOrEmpty(MeasureField("Expression")))
        {
            <p class="muted">No expression available for this measure.</p>
        }
        else
        {
            <pre class="code">@MeasureField("Expression")</pre>
        }
    }
    else if (string.IsNullOrEmpty(selTable))
    {
        <div class="cmd-group">
            <button class="btn-sm @(modelView == ModelView.Tables ? "active" : "")" @onclick="BrowseTables">Tables</button>
            <button class="btn-sm @(modelView == ModelView.Measures ? "active" : "")" @onclick="BrowseMeasures">Measures</button>
            <button class="btn-sm" @onclick="ShowParameters">Parameters</button>
            <button class="btn-sm" @onclick="ShowPartitions">Partitions</button>
            <button class="btn-sm" @onclick="ShowRls">RLS</button>
            <button class="btn-sm" @onclick="ShowDatasources">Datasources</button>
            <button class="btn-sm" @onclick="ShowPermissions">Permissions</button>
            <button class="btn-sm" @onclick="ShowRefreshHistory">Refresh history</button>
            <a class="btn-sm" href="@($"refresh?ws={Uri.EscapeDataString(workspace)}&ds={Uri.EscapeDataString(dataset)}")" title="Refresh this dataset">↻ Refresh…</a>
            <button class="btn" @onclick="GoToQuery">Run DAX →</button>
        </div>
        @if (modelView == ModelView.Tables)
        {
            <ErrorBanner Message="@error" />
            <p class="muted">Click a table to see its M code &amp; partitions, or preview its rows.</p>
            <ClickableList Items="modelTables" OnSelect="SelectTable"
                           Empty="@(busy ? "Loading…" : "No tables.")" />
        }
        else if (modelView == ModelView.Measures)
        {
            <ErrorBanner Message="@error" />
            <p class="muted">Click a measure to see its <strong>DAX definition</strong> and run it.</p>
            <ClickableList Items="modelMeasures" OnSelect="SelectMeasure"
                           Empty="@(busy ? "Loading…" : "No measures.")" />
        }
        else
        {
            @if (busy) { <p class="muted">Running…</p> }
            <ResultGrid Result="result" Error="@error" Empty="Pick a command above." />
        }
    }
    else
    {
        <div class="cmd-group">
            <button class="btn-sm @(tableView == TableView.Mcode ? "active" : "")" @onclick="ShowMcode">M code</button>
            <button class="btn-sm @(tableView == TableView.Partitions ? "active" : "")" @onclick="ShowTablePartitions">Partitions</button>
            <button class="btn-sm" @onclick="() => RunTopN(10)" title="EVALUATE TOPN(10, …) on the DAX tab">Top 10 rows →</button>
            <button class="btn-sm" @onclick="() => RunTopN(100)" title="EVALUATE TOPN(100, …) on the DAX tab">Top 100 rows →</button>
            <a class="btn-sm" href="@RefreshLink()" title="Refresh this dataset on the Refresh page">↻ Refresh…</a>
        </div>

        @if (busy) { <p class="muted">Running…</p> }
        else if (!string.IsNullOrEmpty(error)) { <ErrorBanner Message="@error" /> }
        else if (tableView == TableView.Mcode && result is not null)
        {
            var mcode = SingleCell(result, "QueryDefinition");
            if (string.IsNullOrEmpty(mcode)) { <p class="muted">No M code for this table (it may be a calculated or DirectQuery table).</p> }
            else { <pre class="code">@mcode</pre> }
        }
        else
        {
            <ResultGrid Result="result" Error="@error" Empty="Loading…" />
        }
    }
}

@code {
    private enum Tab { Query, Browse }
    private enum WsView { Datasets, Reports, Lineage }
    private enum ModelView { None, Tables, Measures }
    private enum TableView { Mcode, Partitions }

    private Tab tab = Tab.Browse;
    private WsView wsView = WsView.Datasets;
    private ModelView modelView = ModelView.None;
    private TableView tableView = TableView.Mcode;

    private List<string> workspaces = new();
    private List<string> datasets = new();
    private List<string> modelTables = new();
    private List<string> modelMeasures = new();
    private string workspace = "", dataset = "", dax = "";
    private string? selTable;
    private string? selMeasure;
    private QueryResult? measuresResult;
    private string? defaultWorkspace, defaultDataset;
    private QueryResult? result;
    private string? error;
    private bool busy;
    private IReadOnlyList<QueryEntry> history = Array.Empty<QueryEntry>();

    // DAX-tab fields explorer
    private ModelTree? objects;
    private string? objectsFor;
    private bool objLoading;
    private string? objError;
    private readonly HashSet<string> expandedTables = new();
    private string objSearch = "";
    private bool showFields = true;
    private bool showRecent = true;
    private ElementReference editorRef;
    private bool acAttached;
    private bool acDirty;

    private sealed record AcItem(string Label, string Insert, string Kind);

    // Browse navigation history (browser-style Back).
    private readonly Stack<BrowseState> back = new();
    private bool CanGoBack => back.Count > 0;

    private sealed record BrowseState(
        string Workspace, string Dataset, string? SelTable, string? SelMeasure,
        WsView WsView, ModelView ModelView, TableView TableView,
        List<string> Datasets, List<string> ModelTables, List<string> ModelMeasures,
        QueryResult? MeasuresResult, QueryResult? Result, string? Error);

    private const char Sep = '\u001F'; // table usage Parent = workspace<unit-sep>dataset

    // Deep-link from the "Frequent" sidebar: /explore?ws=..&ds=..&table=..
    [Parameter, SupplyParameterFromQuery(Name = "ws")] public string? Qws { get; set; }
    [Parameter, SupplyParameterFromQuery(Name = "ds")] public string? Qds { get; set; }
    [Parameter, SupplyParameterFromQuery(Name = "table")] public string? Qtable { get; set; }
    private string? appliedQuery;

    private bool HasWorkspace => !string.IsNullOrEmpty(workspace) && !busy;
    private bool HasDataset => HasWorkspace && !string.IsNullOrEmpty(dataset);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var cfg = Ui.Config();
            defaultWorkspace = string.IsNullOrWhiteSpace(cfg.Workspace) ? null : cfg.Workspace;
            defaultDataset = cfg.Dataset;
        }
        catch { /* no default configured */ }

        history = History.Recent(10);

        // Browse is the default tab — load the workspace list up front.
        if (workspaces.Count == 0) await LoadWorkspaces();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(Qws)) return;
        var key = $"{Qws}{Sep}{Qds}{Sep}{Qtable}";
        if (key == appliedQuery) return;   // only apply a given deep-link once
        appliedQuery = key;

        back.Clear();                      // fresh navigation context from the sidebar
        tab = Tab.Browse;
        if (workspaces.Count == 0) await LoadWorkspaces();
        workspace = Qws!;
        await OnWorkspaceChanged();        // loads datasets, records the workspace

        if (!string.IsNullOrEmpty(Qds))
        {
            dataset = Qds!;
            Usage.Record(UsageStore.Dataset, dataset, workspace, UsageStore.ExploreContext);
            if (!string.IsNullOrEmpty(Qtable))
            {
                await SelectTable(Qtable!); // drills in + shows M code + records the table
            }
        }
    }

    // ---- navigation ----

    private async Task EnterBrowse()
    {
        tab = Tab.Browse;
        if (workspaces.Count == 0) await LoadWorkspaces();
    }

    private void BrowseRoot() { PushBack(); workspace = ""; dataset = ""; selTable = null; selMeasure = null; modelView = ModelView.None; result = null; }

    private async Task BrowseWorkspace()
    {
        PushBack();
        dataset = ""; selTable = null; selMeasure = null; modelView = ModelView.None; wsView = WsView.Datasets; result = null;
        if (datasets.Count == 0 && !string.IsNullOrEmpty(workspace)) await OnWorkspaceChanged();
    }

    private void BrowseDataset() { PushBack(); selTable = null; selMeasure = null; modelView = ModelView.None; result = null; }

    private async Task SelectWorkspace(string ws)
    {
        PushBack();
        workspace = ws; selTable = null; selMeasure = null; wsView = WsView.Datasets;
        await OnWorkspaceChanged();
        result = null;
    }

    private void SelectDataset(string ds)
    {
        PushBack();
        dataset = ds; selTable = null; selMeasure = null; modelView = ModelView.None; result = null;
        Usage.Record(UsageStore.Dataset, ds, workspace, UsageStore.ExploreContext);
    }

    private async Task SelectTable(string t)
    {
        PushBack();
        selTable = t; selMeasure = null;
        Usage.Record(UsageStore.Table, t, $"{workspace}{Sep}{dataset}", UsageStore.ExploreContext);
        await ShowMcode();   // show M code by default
    }

    private Task GoToQuery() => ShowQueryTab();

    // ---- DAX-tab fields explorer ----

    private async Task ShowQueryTab()
    {
        tab = Tab.Query;
        if (!string.IsNullOrEmpty(dataset) && objectsFor != dataset) await LoadObjects();
    }

    private async Task OnDatasetPicked()
    {
        objects = null; objectsFor = null; expandedTables.Clear();
        if (tab == Tab.Query && !string.IsNullOrEmpty(dataset)) await LoadObjects();
    }

    private async Task LoadObjects()
    {
        if (string.IsNullOrEmpty(dataset)) return;
        objLoading = true; objError = null; objects = null; StateHasChanged();
        try { objects = await Ui.ModelTreeAsync(workspace, dataset); objectsFor = dataset; acDirty = true; }
        catch (Exception ex) { objError = ex.Message; }
        finally { objLoading = false; }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (tab != Tab.Query) { acAttached = false; return; } // re-attach when the editor re-appears

        // Auto-load the Fields tree for the current dataset (no button).
        if (!string.IsNullOrEmpty(dataset) && objects is null && !objLoading && objError is null && objectsFor != dataset)
        {
            await LoadObjects();
        }

        if (!acAttached)
        {
            try { await JS.InvokeVoidAsync("daxComplete.attach", editorRef); acAttached = true; acDirty = true; }
            catch { /* JS not ready */ }
        }
        if (acAttached && acDirty)
        {
            try { await JS.InvokeVoidAsync("daxComplete.setCandidates", editorRef, BuildCandidates()); acDirty = false; }
            catch { }
        }
    }

    // Functions inserted with "(", keywords as-is; fields from the loaded model.
    private static readonly string[] DaxFunctions =
    {
        "CALCULATE","CALCULATETABLE","FILTER","ALL","ALLEXCEPT","ALLSELECTED","ALLNOBLANKROW","REMOVEFILTERS",
        "KEEPFILTERS","VALUES","DISTINCT","RELATED","RELATEDTABLE","EARLIER","SELECTEDVALUE","HASONEVALUE",
        "SUM","SUMX","AVERAGE","AVERAGEX","MIN","MINX","MAX","MAXX","COUNT","COUNTA","COUNTAX","COUNTX",
        "COUNTROWS","COUNTBLANK","DISTINCTCOUNT","DIVIDE","PRODUCT","PRODUCTX","ROUND","ABS","INT","MOD",
        "IF","IFERROR","SWITCH","AND","OR","NOT","ISBLANK","ISERROR","ISFILTERED","ISINSCOPE","COALESCE",
        "CONCATENATE","CONCATENATEX","FORMAT","LEFT","RIGHT","MID","LEN","UPPER","LOWER","TRIM","SUBSTITUTE",
        "SEARCH","FIND","VALUE","DATE","TODAY","NOW","YEAR","MONTH","DAY","WEEKDAY","WEEKNUM","EOMONTH",
        "EDATE","DATEDIFF","DATEADD","TOTALYTD","TOTALQTD","TOTALMTD","DATESYTD","DATESMTD","SAMEPERIODLASTYEAR",
        "PARALLELPERIOD","PREVIOUSYEAR","PREVIOUSMONTH","NEXTYEAR","NEXTMONTH","FIRSTDATE","LASTDATE",
        "STARTOFMONTH","ENDOFMONTH","DATESBETWEEN","DATESINPERIOD","RANKX","TOPN","ROW","SUMMARIZE",
        "SUMMARIZECOLUMNS","ADDCOLUMNS","SELECTCOLUMNS","GROUPBY","CROSSJOIN","UNION","INTERSECT","EXCEPT",
        "TREATAS","USERELATIONSHIP","CROSSFILTER","CONTAINS","LOOKUPVALUE","USERPRINCIPALNAME",
    };
    private static readonly string[] DaxKeywords =
    {
        "EVALUATE","DEFINE","MEASURE","VAR","RETURN","ORDER BY","START AT","TRUE","FALSE","BLANK()",
    };

    // ---- Format + validate ----

    private void FormatQuery() { dax = FormatDax(dax); }

    private static readonly HashSet<string> DaxUpper =
        new(DaxFunctions.Concat(new[] { "EVALUATE", "DEFINE", "MEASURE", "VAR", "RETURN", "TRUE", "FALSE", "BLANK", "IN", "NOT", "AND", "OR" }),
            StringComparer.OrdinalIgnoreCase);

    /// <summary>Heuristic DAX pretty-printer (local — never sends the query anywhere).</summary>
    private static string FormatDax(string src)
    {
        if (string.IsNullOrWhiteSpace(src)) return src;
        var toks = TokenizeDax(src);

        // match parens; a call breaks across lines only if it contains a nested call.
        var match = new int[toks.Count];
        var st = new Stack<int>();
        for (var x = 0; x < toks.Count; x++)
        {
            if (toks[x].Kind == '(') st.Push(x);
            else if (toks[x].Kind == ')' && st.Count > 0) { var o = st.Pop(); match[o] = x; match[x] = o; }
        }
        var block = new bool[toks.Count];
        for (var x = 0; x < toks.Count; x++)
            if (toks[x].Kind == '(')
            {
                var m = match[x] > x ? match[x] : toks.Count;
                for (var y = x + 1; y < m; y++) if (toks[y].Kind == '(') { block[x] = true; break; }
            }

        var sb = new StringBuilder();
        int indent = 0; bool needSpace = false;
        (char Kind, string Value)? prev = null;
        var blk = new Stack<bool>();
        void NL() { while (sb.Length > 0 && sb[^1] == ' ') sb.Length--; sb.Append('\n').Append(new string(' ', indent * 4)); needSpace = false; }

        for (var x = 0; x < toks.Count; x++)
        {
            var tk = toks[x];
            if (tk.Kind == '(')
            {
                sb.Append('('); blk.Push(block[x]);
                if (block[x]) { indent++; NL(); } else needSpace = false;
                prev = null;
            }
            else if (tk.Kind == ')')
            {
                var b = blk.Count > 0 && blk.Pop();
                if (b) { indent = Math.Max(0, indent - 1); NL(); }
                sb.Append(')'); needSpace = true; prev = tk;
            }
            else if (tk.Kind == ',')
            {
                while (sb.Length > 0 && sb[^1] == ' ') sb.Length--;
                sb.Append(',');
                if (blk.Count > 0 && blk.Peek()) NL(); else { sb.Append(' '); needSpace = false; }
                prev = null;
            }
            else
            {
                var v = tk.Value;
                if (tk.Kind == 'w' && DaxUpper.Contains(v)) v = v.ToUpperInvariant();
                var attach = tk.Kind == 'l' && v.StartsWith("[")
                    && prev is { Kind: 'l' } p && (p.Value.EndsWith("'") || p.Value.EndsWith("]"));
                if (needSpace && !attach) sb.Append(' ');
                sb.Append(v); needSpace = true; prev = tk;
                if (tk.Kind == 'w' && indent == 0 && (v == "EVALUATE" || v == "DEFINE")) { NL(); prev = null; }
            }
        }
        return sb.ToString().Trim();
    }

    private static List<(char Kind, string Value)> TokenizeDax(string s)
    {
        var t = new List<(char, string)>();
        int i = 0, n = s.Length;
        while (i < n)
        {
            var c = s[i];
            if (char.IsWhiteSpace(c)) { i++; continue; }
            if (c == '"' || c == '\'')
            {
                var j = i + 1;
                while (j < n) { if (s[j] == c) { if (j + 1 < n && s[j + 1] == c) { j += 2; continue; } j++; break; } j++; }
                t.Add(('l', s[i..j])); i = j; continue;
            }
            if (c == '[')
            {
                var j = i + 1;
                while (j < n && s[j] != ']') j++;
                if (j < n) j++;
                t.Add(('l', s[i..j])); i = j; continue;
            }
            if (c is '(' or ')' or ',') { t.Add((c, c.ToString())); i++; continue; }
            var k = i;
            while (k < n && !char.IsWhiteSpace(s[k]) && s[k] is not ('(' or ')' or ',' or '"' or '\'' or '[')) k++;
            t.Add(('w', s[i..k])); i = k;
        }
        return t;
    }

    /// <summary>Quick static checks — unbalanced delimiters and the missing-EVALUATE case.</summary>
    private List<string> DaxIssues()
    {
        var issues = new List<string>();
        if (string.IsNullOrWhiteSpace(dax)) return issues;
        int paren = 0, bracket = 0; bool inStr = false, inTick = false;
        for (var i = 0; i < dax.Length; i++)
        {
            var c = dax[i];
            if (inStr) { if (c == '"') { if (i + 1 < dax.Length && dax[i + 1] == '"') i++; else inStr = false; } continue; }
            if (inTick) { if (c == '\'') { if (i + 1 < dax.Length && dax[i + 1] == '\'') i++; else inTick = false; } continue; }
            if (c == '"') inStr = true;
            else if (c == '\'') inTick = true;
            else if (c == '(') paren++;
            else if (c == ')') { if (paren == 0) { issues.Add("Extra ')' — a closing parenthesis with no opener."); } else paren--; }
            else if (c == '[') bracket++;
            else if (c == ']') { if (bracket == 0) { issues.Add("Extra ']' — a closing bracket with no opener."); } else bracket--; }
        }
        if (inStr) issues.Add("Unclosed string — a \" is never closed.");
        if (inTick) issues.Add("Unclosed table name — a ' is never closed.");
        if (paren > 0) issues.Add($"{paren} unclosed '(' — missing {paren} ')'.");
        if (bracket > 0) issues.Add($"{bracket} unclosed '[' — missing {bracket} ']' (a column / measure reference).");
        var trimmed = dax.TrimStart();
        if (trimmed.Length > 0 && !trimmed.StartsWith("EVALUATE", StringComparison.OrdinalIgnoreCase)
            && !trimmed.StartsWith("DEFINE", StringComparison.OrdinalIgnoreCase))
            issues.Add("A DAX query should start with EVALUATE (or DEFINE).");
        return issues;
    }

    private AcItem[] BuildCandidates()
    {
        var list = new List<AcItem>();
        foreach (var f in DaxFunctions) list.Add(new AcItem(f, f + "(", "function"));
        foreach (var k in DaxKeywords) list.Add(new AcItem(k, k.EndsWith(")") ? k : k + " ", "keyword"));

        if (objects is not null)
        {
            foreach (var t in objects.Tables)
            {
                var tref = "'" + t.Table.Replace("'", "''") + "'";
                list.Add(new AcItem("'" + t.Table + "'", tref, "table"));
                foreach (var o in t.Items)
                {
                    if (o.IsMeasure)
                        list.Add(new AcItem("[" + o.Name + "]", "[" + o.Name.Replace("]", "]]") + "]", "measure"));
                    else
                        list.Add(new AcItem("'" + t.Table + "'[" + o.Name + "]", tref + "[" + o.Name.Replace("]", "]]") + "]", "column"));
                }
            }
        }
        return list.ToArray();
    }

    private bool IsExpanded(string table) => !string.IsNullOrEmpty(objSearch) || expandedTables.Contains(table);
    private void ToggleTable(string table) { if (!expandedTables.Remove(table)) expandedTables.Add(table); }

    private IEnumerable<ModelTableNode> FilteredTables()
    {
        if (objects is null) yield break;
        var q = objSearch?.Trim();
        foreach (var t in objects.Tables)
        {
            if (string.IsNullOrEmpty(q)
                || t.Table.Contains(q, StringComparison.OrdinalIgnoreCase)
                || t.Items.Any(o => o.Name.Contains(q, StringComparison.OrdinalIgnoreCase)))
                yield return t;
        }
    }

    private IEnumerable<ModelObject> FilteredItems(ModelTableNode t)
    {
        var q = objSearch?.Trim();
        if (string.IsNullOrEmpty(q) || t.Table.Contains(q, StringComparison.OrdinalIgnoreCase))
            return t.Items;
        return t.Items.Where(o => o.Name.Contains(q, StringComparison.OrdinalIgnoreCase));
    }

    private void InsertTable(string table) => Append("'" + table.Replace("'", "''") + "'");

    private void InsertRef(string table, ModelObject o)
    {
        var name = o.Name.Replace("]", "]]");
        Append(o.IsMeasure ? "[" + name + "]" : "'" + table.Replace("'", "''") + "'[" + name + "]");
    }

    private void Append(string reference)
    {
        var sep = string.IsNullOrEmpty(dax) || dax.EndsWith(" ") || dax.EndsWith("\n") ? "" : " ";
        dax = dax + sep + reference;
    }

    private async Task LoadDefault()
    {
        if (string.IsNullOrEmpty(defaultWorkspace)) return;
        workspace = defaultWorkspace;
        await OnWorkspaceChanged();
        if (!string.IsNullOrEmpty(defaultDataset)) dataset = defaultDataset!;
    }

    // Clear the combo so its full datalist shows again (native datalist filters to the current value).
    private async Task ClearWorkspace() { workspace = ""; await OnWorkspaceChanged(); } // also clears datasets/dataset
    private void ClearDataset() => dataset = "";

    private async Task LoadWorkspaces()
    {
        busy = true; error = null;
        try { workspaces = ColumnValues(await Ui.WorkspacesAsync(), "name"); }
        catch (Exception ex) { error = ex.Message; }
        finally { busy = false; }
    }

    private async Task OnWorkspaceChanged()
    {
        datasets = new(); dataset = ""; selTable = null; selMeasure = null;
        if (string.IsNullOrEmpty(workspace)) return;
        busy = true; error = null;
        try
        {
            datasets = ColumnValues(await Ui.DatasetsAsync(workspace), "name");
            Usage.Record(UsageStore.Workspace, workspace, null, UsageStore.ExploreContext); // valid workspace (it resolved)
        }
        catch (Exception ex) { error = ex.Message; }
        finally { busy = false; }
    }

    // ---- commands ----

    private Task BrowseDatasets() { wsView = WsView.Datasets; result = null; return Task.CompletedTask; }
    private Task ShowReports() { PushBack(); wsView = WsView.Reports; return Show(() => Ui.ReportsAsync(workspace)); }
    private Task ShowLineage() { PushBack(); wsView = WsView.Lineage; return Show(() => Ui.LineageAsync(workspace)); }

    private async Task BrowseTables()
    {
        PushBack();
        modelView = ModelView.Tables; result = null; error = null; busy = true; StateHasChanged();
        try { modelTables = ColumnValues(await Ui.TablesAsync(workspace, dataset), "Table"); }
        catch (Exception ex) { error = ex.Message; }
        finally { busy = false; }
    }

    private async Task BrowseMeasures()
    {
        PushBack();
        modelView = ModelView.Measures; result = null; error = null; busy = true; StateHasChanged();
        try
        {
            measuresResult = await Ui.MeasuresAsync(workspace, dataset); // keeps Name + Expression + folder
            modelMeasures = ColumnValues(measuresResult, "Name");
        }
        catch (Exception ex) { error = ex.Message; }
        finally { busy = false; }
    }

    private void SelectMeasure(string measure)
    {
        PushBack();
        selMeasure = measure; result = null; error = null;
    }

    /// <summary>A column value for the selected measure, from the loaded measures result.</summary>
    private string? MeasureField(string column)
    {
        if (measuresResult is null || string.IsNullOrEmpty(selMeasure)) return null;
        var nameIdx = ColIndex(measuresResult, "Name");
        var colIdx = ColIndex(measuresResult, column);
        if (nameIdx < 0 || colIdx < 0) return null;
        foreach (var row in measuresResult.Rows)
            if (string.Equals(row[nameIdx]?.ToString(), selMeasure, StringComparison.Ordinal))
                return row[colIdx]?.ToString();
        return null;
    }

    private static int ColIndex(QueryResult r, string column)
    {
        for (var i = 0; i < r.Columns.Count; i++)
            if (string.Equals(r.Columns[i], column, StringComparison.OrdinalIgnoreCase)) return i;
        return -1;
    }

    // ---- quick "run it" actions: prefill the DAX tab and execute ----

    private async Task GoRunDax(string daxQuery)
    {
        dax = daxQuery;
        tab = Tab.Query;
        await RunQuery();
    }

    private Task RunTopN(int n)
    {
        var t = selTable!.Replace("'", "''");
        return GoRunDax("EVALUATE\nTOPN(" + n + ", '" + t + "')");
    }

    private Task RunMeasure(string measure)
    {
        var label = measure.Replace("\"", "\"\"");
        var name = measure.Replace("]", "]]");
        return GoRunDax("EVALUATE\nROW(\"" + label + "\", [" + name + "])");
    }

    // Model commands push a back-state first, so Back returns to the dataset's command view.
    private Task Cmd(Func<Task<QueryResult>> op) { PushBack(); return Show(op); }
    private Task ShowParameters() => Cmd(() => Ui.ParametersAsync(workspace, dataset));
    private Task ShowPartitions() => Cmd(() => Ui.PartitionsAsync(workspace, dataset));
    private Task ShowRls() => Cmd(() => Ui.RlsAsync(workspace, dataset));
    private Task ShowDatasources() => Cmd(() => Ui.DatasourcesAsync(workspace, dataset));
    private Task ShowPermissions() => Cmd(() => Ui.PermissionsAsync(workspace, dataset));
    private Task ShowRefreshHistory() => Cmd(() => Ui.RefreshHistoryAsync(workspace, dataset));
    private async Task RunQuery()
    {
        await Show(() => Ui.QueryAsync(workspace, dataset, dax));
        if (error is null)
        {
            if (!string.IsNullOrEmpty(dataset))
                Usage.Record(UsageStore.Dataset, dataset, workspace, UsageStore.ExploreContext); // dataset proven valid by a successful query
            History.Record(dax, workspace, dataset);                  // remember the query for one-click re-run
            history = History.Recent(10);
        }
    }

    private async Task RunHistory(QueryEntry h)
    {
        tab = Tab.Query;
        workspace = h.Workspace;
        dataset = h.Dataset ?? "";
        dax = h.Dax;
        await RunQuery();
    }

    private void RemoveHistory(QueryEntry h)
    {
        History.Remove(h.Dax, h.Workspace, h.Dataset);
        history = History.Recent(10);
    }

    private void ClearHistory()
    {
        History.Clear();
        history = Array.Empty<QueryEntry>();
    }

    private static string Preview(string dax)
    {
        var oneLine = string.Join(' ', dax.Split('\n', '\r', '\t')
            .Select(s => s.Trim()).Where(s => s.Length > 0));
        return oneLine.Length > 80 ? oneLine[..80] + "…" : oneLine;
    }

    private Task ShowMcode() { tableView = TableView.Mcode; return Show(() => Ui.McodeAsync(workspace, dataset, selTable!)); }
    private Task ShowTablePartitions() { tableView = TableView.Partitions; return Show(() => Ui.TablePartitionsAsync(workspace, dataset, selTable!)); }

    // Deep-link to the dedicated Refresh page with this table preselected.
    // Refresh links only carry workspace + dataset; the user picks the scope on the Refresh page.
    private string RefreshLink()
        => $"refresh?ws={Uri.EscapeDataString(workspace)}&ds={Uri.EscapeDataString(dataset)}";

    private async Task Show(Func<Task<QueryResult>> op)
    {
        modelView = ModelView.None;
        busy = true; error = null; result = null; StateHasChanged();
        try { result = await op(); }
        catch (Exception ex) { error = ex.Message; }
        finally { busy = false; }
    }

    // ---- Back navigation ----

    private void PushBack() => back.Push(new BrowseState(
        workspace, dataset, selTable, selMeasure, wsView, modelView, tableView,
        datasets, modelTables, modelMeasures, measuresResult, result, error));

    private void GoBack()
    {
        if (back.Count == 0) return;
        var s = back.Pop();
        workspace = s.Workspace; dataset = s.Dataset; selTable = s.SelTable; selMeasure = s.SelMeasure;
        wsView = s.WsView; modelView = s.ModelView; tableView = s.TableView;
        datasets = s.Datasets; modelTables = s.ModelTables; modelMeasures = s.ModelMeasures;
        measuresResult = s.MeasuresResult; result = s.Result; error = s.Error;
        busy = false;
    }

    private static string? SingleCell(QueryResult r, string column)
    {
        if (r.Rows.Count == 0) return null;
        for (var i = 0; i < r.Columns.Count; i++)
            if (string.Equals(r.Columns[i], column, StringComparison.OrdinalIgnoreCase))
                return r.Rows[0][i]?.ToString();
        return null;
    }

    private static List<string> ColumnValues(QueryResult r, string column)
    {
        var idx = -1;
        for (var i = 0; i < r.Columns.Count; i++)
            if (string.Equals(r.Columns[i], column, StringComparison.OrdinalIgnoreCase)) { idx = i; break; }
        if (idx < 0) return new();
        return r.Rows.Select(row => row[idx]?.ToString() ?? "")
                     .Where(s => s.Length > 0).OrderBy(s => s).ToList();
    }
}
