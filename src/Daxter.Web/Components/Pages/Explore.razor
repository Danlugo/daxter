@page "/explore"
@inject DaxterUi Ui
@inject UsageStore Usage
@inject QueryHistoryStore History

<PageTitle>DAXter — Explore</PageTitle>

<h1>Explore</h1>
<p class="muted">Browse models and run commands — the CLI/MCP capabilities, graphically.</p>

<div class="row">
    <div>
        <label>Workspace <span class="muted">(@workspaces.Count — type to search)</span></label>
        <div class="combo-wrap">
            <input class="combo" list="ws-list" @bind="workspace" @bind:after="OnWorkspaceChanged"
                   placeholder="type to search…" autocomplete="off" onfocus="this.select()" />
            @if (!string.IsNullOrEmpty(workspace))
            {
                <button class="combo-clear" @onclick="ClearWorkspace" title="Clear — pick another workspace">×</button>
            }
        </div>
        <datalist id="ws-list">@foreach (var w in workspaces) { <option value="@w"></option> }</datalist>
        <button class="btn-sm" @onclick="LoadWorkspaces" disabled="@busy">Load</button>
    </div>
    <div>
        <label>Dataset <span class="muted">(@datasets.Count)</span></label>
        <div class="combo-wrap">
            <input class="combo" list="ds-list" @bind="dataset" placeholder="type to search…"
                   autocomplete="off" onfocus="this.select()" />
            @if (!string.IsNullOrEmpty(dataset))
            {
                <button class="combo-clear" @onclick="ClearDataset" title="Clear — pick another dataset">×</button>
            }
        </div>
        <datalist id="ds-list">@foreach (var d in datasets) { <option value="@d"></option> }</datalist>
    </div>
</div>

@if (!string.IsNullOrEmpty(defaultWorkspace))
{
    <p>
        <button class="link" @onclick="LoadDefault" disabled="@busy">
            ⤓ Load default: @defaultWorkspace@(string.IsNullOrEmpty(defaultDataset) ? "" : " / " + defaultDataset)
        </button>
    </p>
}

<div class="tabs">
    <button class="tab @(tab == Tab.Browse ? "active" : "")" @onclick="EnterBrowse">Browse</button>
    <button class="tab @(tab == Tab.Query ? "active" : "")" @onclick="@(() => tab = Tab.Query)">DAX query</button>
</div>

@if (tab == Tab.Query)
{
    <div class="query">
        <textarea @bind="dax" rows="4" placeholder="EVALUATE TOPN(10, 'Table')"></textarea>
        <button class="btn" @onclick="RunQuery" disabled="@(!HasDataset)">Run DAX</button>
    </div>

    @if (history.Count > 0)
    {
        <div class="history">
            <div class="hist-head">
                <span class="side-h">Recent queries</span>
                <button class="link" @onclick="ClearHistory">clear all</button>
            </div>
            <ul class="hist-list">
                @foreach (var h in history)
                {
                    <li class="hist-item">
                        <button class="hist-run" @onclick="() => RunHistory(h)" title="@h.Dax — click to run">
                            <span class="hist-dax">@Preview(h.Dax)</span>
                            <span class="hist-ctx">@(string.IsNullOrEmpty(h.Dataset) ? h.Workspace : h.Dataset) · @(h.Count)×</span>
                        </button>
                        <button class="hist-del" @onclick="() => RemoveHistory(h)" title="Remove">×</button>
                    </li>
                }
            </ul>
        </div>
    }

    @if (busy) { <p class="muted">Running…</p> }
    <ResultGrid Result="result" Error="@error" Empty="Pick a dataset and run a query." />
}
else
{
    <nav class="crumbs">
        <button class="btn-sm back-btn" @onclick="GoBack" disabled="@(!CanGoBack)" title="Back to the previous view">← Back</button>
        <button class="link" @onclick="BrowseRoot">Workspaces</button>
        @if (!string.IsNullOrEmpty(workspace))
        {
            <span>›</span><button class="link" @onclick="BrowseWorkspace">@workspace</button>
        }
        @if (!string.IsNullOrEmpty(dataset))
        {
            <span>›</span>
            @if (!string.IsNullOrEmpty(selTable)) { <button class="link" @onclick="BrowseDataset">@dataset</button> }
            else { <span class="crumb-current">@dataset</span> }
        }
        @if (!string.IsNullOrEmpty(selTable))
        {
            <span>›</span><span class="crumb-current">@selTable</span>
        }
    </nav>

    @if (string.IsNullOrEmpty(workspace))
    {
        <ErrorBanner Message="@error" />
        <ClickableList Items="workspaces" OnSelect="SelectWorkspace"
                       Empty="@(busy ? "Loading…" : "No workspaces — click Load.")" />
    }
    else if (string.IsNullOrEmpty(dataset))
    {
        <div class="cmd-group">
            <button class="btn-sm @(wsView == WsView.Datasets ? "active" : "")" @onclick="BrowseDatasets">Datasets</button>
            <button class="btn-sm @(wsView == WsView.Reports ? "active" : "")" @onclick="ShowReports">Reports</button>
            <button class="btn-sm @(wsView == WsView.Lineage ? "active" : "")" @onclick="ShowLineage">Lineage</button>
        </div>
        @if (wsView == WsView.Datasets)
        {
            <ErrorBanner Message="@error" />
            <ClickableList Items="datasets" OnSelect="SelectDataset"
                           Empty="@(busy ? "Loading…" : "No datasets in this workspace.")" />
        }
        else
        {
            @if (busy) { <p class="muted">Running…</p> }
            <ResultGrid Result="result" Error="@error" />
        }
    }
    else if (string.IsNullOrEmpty(selTable))
    {
        <div class="cmd-group">
            <button class="btn-sm @(modelView == ModelView.Tables ? "active" : "")" @onclick="BrowseTables">Tables</button>
            <button class="btn-sm @(modelView == ModelView.Measures ? "active" : "")" @onclick="BrowseMeasures">Measures</button>
            <button class="btn-sm" @onclick="ShowParameters">Parameters</button>
            <button class="btn-sm" @onclick="ShowPartitions">Partitions</button>
            <button class="btn-sm" @onclick="ShowRls">RLS</button>
            <button class="btn-sm" @onclick="ShowDatasources">Datasources</button>
            <button class="btn-sm" @onclick="ShowPermissions">Permissions</button>
            <button class="btn-sm" @onclick="ShowRefreshHistory">Refresh history</button>
            <a class="btn-sm" href="@($"refresh?ws={Uri.EscapeDataString(workspace)}&ds={Uri.EscapeDataString(dataset)}")" title="Refresh this dataset">↻ Refresh…</a>
            <button class="btn" @onclick="GoToQuery">Run DAX →</button>
        </div>
        @if (modelView == ModelView.Tables)
        {
            <ErrorBanner Message="@error" />
            <p class="muted">Click a table to see its M code &amp; partitions, or preview its rows.</p>
            <ClickableList Items="modelTables" OnSelect="SelectTable"
                           Empty="@(busy ? "Loading…" : "No tables.")" />
        }
        else if (modelView == ModelView.Measures)
        {
            <ErrorBanner Message="@error" />
            <p class="muted">Click a measure to <strong>run it</strong> (evaluates the measure and shows its value).</p>
            <ClickableList Items="modelMeasures" OnSelect="RunMeasure"
                           Empty="@(busy ? "Loading…" : "No measures.")" />
        }
        else
        {
            @if (busy) { <p class="muted">Running…</p> }
            <ResultGrid Result="result" Error="@error" Empty="Pick a command above." />
        }
    }
    else
    {
        <div class="cmd-group">
            <button class="btn-sm @(tableView == TableView.Mcode ? "active" : "")" @onclick="ShowMcode">M code</button>
            <button class="btn-sm @(tableView == TableView.Partitions ? "active" : "")" @onclick="ShowTablePartitions">Partitions</button>
            <button class="btn-sm" @onclick="() => RunTopN(10)" title="EVALUATE TOPN(10, …) on the DAX tab">Top 10 rows →</button>
            <button class="btn-sm" @onclick="() => RunTopN(100)" title="EVALUATE TOPN(100, …) on the DAX tab">Top 100 rows →</button>
            <a class="btn-sm" href="@RefreshLink()" title="Refresh this dataset on the Refresh page">↻ Refresh…</a>
        </div>

        @if (busy) { <p class="muted">Running…</p> }
        else if (!string.IsNullOrEmpty(error)) { <ErrorBanner Message="@error" /> }
        else if (tableView == TableView.Mcode && result is not null)
        {
            var mcode = SingleCell(result, "QueryDefinition");
            if (string.IsNullOrEmpty(mcode)) { <p class="muted">No M code for this table (it may be a calculated or DirectQuery table).</p> }
            else { <pre class="code">@mcode</pre> }
        }
        else
        {
            <ResultGrid Result="result" Error="@error" Empty="Loading…" />
        }
    }
}

@code {
    private enum Tab { Query, Browse }
    private enum WsView { Datasets, Reports, Lineage }
    private enum ModelView { None, Tables, Measures }
    private enum TableView { Mcode, Partitions }

    private Tab tab = Tab.Browse;
    private WsView wsView = WsView.Datasets;
    private ModelView modelView = ModelView.None;
    private TableView tableView = TableView.Mcode;

    private List<string> workspaces = new();
    private List<string> datasets = new();
    private List<string> modelTables = new();
    private List<string> modelMeasures = new();
    private string workspace = "", dataset = "", dax = "";
    private string? selTable;
    private string? defaultWorkspace, defaultDataset;
    private QueryResult? result;
    private string? error;
    private bool busy;
    private IReadOnlyList<QueryEntry> history = Array.Empty<QueryEntry>();

    // Browse navigation history (browser-style Back).
    private readonly Stack<BrowseState> back = new();
    private bool CanGoBack => back.Count > 0;

    private sealed record BrowseState(
        string Workspace, string Dataset, string? SelTable,
        WsView WsView, ModelView ModelView, TableView TableView,
        List<string> Datasets, List<string> ModelTables, List<string> ModelMeasures, QueryResult? Result, string? Error);

    private const char Sep = '\u001F'; // table usage Parent = workspace<unit-sep>dataset

    // Deep-link from the "Frequent" sidebar: /explore?ws=..&ds=..&table=..
    [Parameter, SupplyParameterFromQuery(Name = "ws")] public string? Qws { get; set; }
    [Parameter, SupplyParameterFromQuery(Name = "ds")] public string? Qds { get; set; }
    [Parameter, SupplyParameterFromQuery(Name = "table")] public string? Qtable { get; set; }
    private string? appliedQuery;

    private bool HasWorkspace => !string.IsNullOrEmpty(workspace) && !busy;
    private bool HasDataset => HasWorkspace && !string.IsNullOrEmpty(dataset);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var cfg = Ui.Config();
            defaultWorkspace = string.IsNullOrWhiteSpace(cfg.Workspace) ? null : cfg.Workspace;
            defaultDataset = cfg.Dataset;
        }
        catch { /* no default configured */ }

        history = History.Recent(10);

        // Browse is the default tab — load the workspace list up front.
        if (workspaces.Count == 0) await LoadWorkspaces();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(Qws)) return;
        var key = $"{Qws}{Sep}{Qds}{Sep}{Qtable}";
        if (key == appliedQuery) return;   // only apply a given deep-link once
        appliedQuery = key;

        back.Clear();                      // fresh navigation context from the sidebar
        tab = Tab.Browse;
        if (workspaces.Count == 0) await LoadWorkspaces();
        workspace = Qws!;
        await OnWorkspaceChanged();        // loads datasets, records the workspace

        if (!string.IsNullOrEmpty(Qds))
        {
            dataset = Qds!;
            Usage.Record(UsageStore.Dataset, dataset, workspace, UsageStore.ExploreContext);
            if (!string.IsNullOrEmpty(Qtable))
            {
                await SelectTable(Qtable!); // drills in + shows M code + records the table
            }
        }
    }

    // ---- navigation ----

    private async Task EnterBrowse()
    {
        tab = Tab.Browse;
        if (workspaces.Count == 0) await LoadWorkspaces();
    }

    private void BrowseRoot() { PushBack(); workspace = ""; dataset = ""; selTable = null; modelView = ModelView.None; result = null; }

    private async Task BrowseWorkspace()
    {
        PushBack();
        dataset = ""; selTable = null; modelView = ModelView.None; wsView = WsView.Datasets; result = null;
        if (datasets.Count == 0 && !string.IsNullOrEmpty(workspace)) await OnWorkspaceChanged();
    }

    private void BrowseDataset() { PushBack(); selTable = null; modelView = ModelView.None; result = null; }

    private async Task SelectWorkspace(string ws)
    {
        PushBack();
        workspace = ws; selTable = null; wsView = WsView.Datasets;
        await OnWorkspaceChanged();
        result = null;
    }

    private void SelectDataset(string ds)
    {
        PushBack();
        dataset = ds; selTable = null; modelView = ModelView.None; result = null;
        Usage.Record(UsageStore.Dataset, ds, workspace, UsageStore.ExploreContext);
    }

    private async Task SelectTable(string t)
    {
        PushBack();
        selTable = t;
        Usage.Record(UsageStore.Table, t, $"{workspace}{Sep}{dataset}", UsageStore.ExploreContext);
        await ShowMcode();   // show M code by default
    }

    private void GoToQuery() => tab = Tab.Query;

    private async Task LoadDefault()
    {
        if (string.IsNullOrEmpty(defaultWorkspace)) return;
        workspace = defaultWorkspace;
        await OnWorkspaceChanged();
        if (!string.IsNullOrEmpty(defaultDataset)) dataset = defaultDataset!;
    }

    // Clear the combo so its full datalist shows again (native datalist filters to the current value).
    private async Task ClearWorkspace() { workspace = ""; await OnWorkspaceChanged(); } // also clears datasets/dataset
    private void ClearDataset() => dataset = "";

    private async Task LoadWorkspaces()
    {
        busy = true; error = null;
        try { workspaces = ColumnValues(await Ui.WorkspacesAsync(), "name"); }
        catch (Exception ex) { error = ex.Message; }
        finally { busy = false; }
    }

    private async Task OnWorkspaceChanged()
    {
        datasets = new(); dataset = ""; selTable = null;
        if (string.IsNullOrEmpty(workspace)) return;
        busy = true; error = null;
        try
        {
            datasets = ColumnValues(await Ui.DatasetsAsync(workspace), "name");
            Usage.Record(UsageStore.Workspace, workspace, null, UsageStore.ExploreContext); // valid workspace (it resolved)
        }
        catch (Exception ex) { error = ex.Message; }
        finally { busy = false; }
    }

    // ---- commands ----

    private Task BrowseDatasets() { wsView = WsView.Datasets; result = null; return Task.CompletedTask; }
    private Task ShowReports() { PushBack(); wsView = WsView.Reports; return Show(() => Ui.ReportsAsync(workspace)); }
    private Task ShowLineage() { PushBack(); wsView = WsView.Lineage; return Show(() => Ui.LineageAsync(workspace)); }

    private async Task BrowseTables()
    {
        PushBack();
        modelView = ModelView.Tables; result = null; error = null; busy = true; StateHasChanged();
        try { modelTables = ColumnValues(await Ui.TablesAsync(workspace, dataset), "Table"); }
        catch (Exception ex) { error = ex.Message; }
        finally { busy = false; }
    }

    private async Task BrowseMeasures()
    {
        PushBack();
        modelView = ModelView.Measures; result = null; error = null; busy = true; StateHasChanged();
        try { modelMeasures = ColumnValues(await Ui.MeasuresAsync(workspace, dataset), "Name"); }
        catch (Exception ex) { error = ex.Message; }
        finally { busy = false; }
    }

    // ---- quick "run it" actions: prefill the DAX tab and execute ----

    private async Task GoRunDax(string daxQuery)
    {
        dax = daxQuery;
        tab = Tab.Query;
        await RunQuery();
    }

    private Task RunTopN(int n)
    {
        var t = selTable!.Replace("'", "''");
        return GoRunDax("EVALUATE\nTOPN(" + n + ", '" + t + "')");
    }

    private Task RunMeasure(string measure)
    {
        var label = measure.Replace("\"", "\"\"");
        var name = measure.Replace("]", "]]");
        return GoRunDax("EVALUATE\nROW(\"" + label + "\", [" + name + "])");
    }

    // Model commands push a back-state first, so Back returns to the dataset's command view.
    private Task Cmd(Func<Task<QueryResult>> op) { PushBack(); return Show(op); }
    private Task ShowParameters() => Cmd(() => Ui.ParametersAsync(workspace, dataset));
    private Task ShowPartitions() => Cmd(() => Ui.PartitionsAsync(workspace, dataset));
    private Task ShowRls() => Cmd(() => Ui.RlsAsync(workspace, dataset));
    private Task ShowDatasources() => Cmd(() => Ui.DatasourcesAsync(workspace, dataset));
    private Task ShowPermissions() => Cmd(() => Ui.PermissionsAsync(workspace, dataset));
    private Task ShowRefreshHistory() => Cmd(() => Ui.RefreshHistoryAsync(workspace, dataset));
    private async Task RunQuery()
    {
        await Show(() => Ui.QueryAsync(workspace, dataset, dax));
        if (error is null)
        {
            if (!string.IsNullOrEmpty(dataset))
                Usage.Record(UsageStore.Dataset, dataset, workspace, UsageStore.ExploreContext); // dataset proven valid by a successful query
            History.Record(dax, workspace, dataset);                  // remember the query for one-click re-run
            history = History.Recent(10);
        }
    }

    private async Task RunHistory(QueryEntry h)
    {
        tab = Tab.Query;
        workspace = h.Workspace;
        dataset = h.Dataset ?? "";
        dax = h.Dax;
        await RunQuery();
    }

    private void RemoveHistory(QueryEntry h)
    {
        History.Remove(h.Dax, h.Workspace, h.Dataset);
        history = History.Recent(10);
    }

    private void ClearHistory()
    {
        History.Clear();
        history = Array.Empty<QueryEntry>();
    }

    private static string Preview(string dax)
    {
        var oneLine = string.Join(' ', dax.Split('\n', '\r', '\t')
            .Select(s => s.Trim()).Where(s => s.Length > 0));
        return oneLine.Length > 80 ? oneLine[..80] + "…" : oneLine;
    }

    private Task ShowMcode() { tableView = TableView.Mcode; return Show(() => Ui.McodeAsync(workspace, dataset, selTable!)); }
    private Task ShowTablePartitions() { tableView = TableView.Partitions; return Show(() => Ui.TablePartitionsAsync(workspace, dataset, selTable!)); }

    // Deep-link to the dedicated Refresh page with this table preselected.
    // Refresh links only carry workspace + dataset; the user picks the scope on the Refresh page.
    private string RefreshLink()
        => $"refresh?ws={Uri.EscapeDataString(workspace)}&ds={Uri.EscapeDataString(dataset)}";

    private async Task Show(Func<Task<QueryResult>> op)
    {
        modelView = ModelView.None;
        busy = true; error = null; result = null; StateHasChanged();
        try { result = await op(); }
        catch (Exception ex) { error = ex.Message; }
        finally { busy = false; }
    }

    // ---- Back navigation ----

    private void PushBack() => back.Push(new BrowseState(
        workspace, dataset, selTable, wsView, modelView, tableView,
        datasets, modelTables, modelMeasures, result, error));

    private void GoBack()
    {
        if (back.Count == 0) return;
        var s = back.Pop();
        workspace = s.Workspace; dataset = s.Dataset; selTable = s.SelTable;
        wsView = s.WsView; modelView = s.ModelView; tableView = s.TableView;
        datasets = s.Datasets; modelTables = s.ModelTables; modelMeasures = s.ModelMeasures;
        result = s.Result; error = s.Error;
        busy = false;
    }

    private static string? SingleCell(QueryResult r, string column)
    {
        if (r.Rows.Count == 0) return null;
        for (var i = 0; i < r.Columns.Count; i++)
            if (string.Equals(r.Columns[i], column, StringComparison.OrdinalIgnoreCase))
                return r.Rows[0][i]?.ToString();
        return null;
    }

    private static List<string> ColumnValues(QueryResult r, string column)
    {
        var idx = -1;
        for (var i = 0; i < r.Columns.Count; i++)
            if (string.Equals(r.Columns[i], column, StringComparison.OrdinalIgnoreCase)) { idx = i; break; }
        if (idx < 0) return new();
        return r.Rows.Select(row => row[idx]?.ToString() ?? "")
                     .Where(s => s.Length > 0).OrderBy(s => s).ToList();
    }
}
