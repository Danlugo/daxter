@page "/"
@inject DaxterUi Ui
@inject IJSRuntime JS
@inject VersionService Version

<PageTitle>DAXter — Status</PageTitle>

<h1>Status &amp; health</h1>
<p class="muted">Is this server ready to query Power BI / serve as an MCP server?</p>

<button class="btn" @onclick="RunAsync" disabled="@busy">@(busy ? "Checking…" : "Run health check")</button>

@if (checks is not null)
{
    <ul class="checks">
        @foreach (var c in checks)
        {
            <li class="@(c.Ok ? "ok" : "bad")">
                <span class="dot"></span><strong>@c.Name</strong> — @c.Detail
            </li>
        }
    </ul>
}

@if (needsLogin)
{
    <div class="card">
        <h3>Sign in to Power BI</h3>
        @if (loginMsg is null)
        {
            <button class="btn" @onclick="LoginAsync" disabled="@loggingIn">
                @(loggingIn ? "Starting…" : "Sign in")
            </button>
        }
        else if (!string.IsNullOrEmpty(verificationUrl))
        {
            <p>
                1. Open
                <a href="@verificationUrl" target="_blank" rel="noopener noreferrer">@verificationUrl ↗</a>
                &nbsp;2. Enter this code:
            </p>
            <div class="device-code">
                <code class="usercode">@userCode</code>
                <button class="btn-sm" @onclick="CopyCode">@(copied ? "Copied ✓" : "Copy code")</button>
            </div>
            @if (loginError is not null)
            {
                <p class="bad-text">@loginError</p>
            }
            else if (awaitingAuth)
            {
                <p class="muted">Waiting for you to finish signing in in your browser… this page updates automatically.</p>
            }
            <button class="btn" @onclick="RunAsync">@(awaitingAuth ? "Re-check now" : "I've signed in — re-check")</button>
        }
        else
        {
            <pre class="code">@loginMsg</pre>
            @if (loginError is not null) { <p class="bad-text">@loginError</p> }
            <button class="btn" @onclick="RunAsync">I've signed in — re-check</button>
        }
    </div>
}

<div class="card">
    <h3>Version &amp; updates</h3>
    <p>
        Running <strong>@Version.Current</strong> ·
        <a href="@Version.RepoUrl" target="_blank" rel="noopener noreferrer">GitHub ↗</a>
    </p>
    <button class="btn-sm" @onclick="CheckUpdatesAsync" disabled="@checkingUpdate">
        @(checkingUpdate ? "Checking…" : "Check for updates")
    </button>

    @if (update is not null)
    {
        @switch (update.State)
        {
            case UpdateState.UpToDate:
                <p class="ok-text">✓ You're on the latest release (@update.Latest).</p>
                break;

            case UpdateState.UpdateAvailable:
                <div class="card bad" style="margin-top:.8rem;">
                    <p><strong>Update available:</strong> @update.Latest
                        (you have @update.Current) ·
                        <a href="@update.Url" target="_blank" rel="noopener noreferrer">Release notes ↗</a>
                    </p>
                    <p class="muted">Upgrade — reuses the same volume, so your sign-in and Configure settings are kept:</p>
                    <pre class="code">@UpgradeCommands()</pre>
                    <p class="muted">Or just ask Claude: <em>"upgrade my DAXter container and keep the volume."</em></p>
                </div>
                break;

            case UpdateState.Dev:
                <p class="muted">You're running a local <code>dev</code> build. Latest release: @(@update.Latest ?? "unknown").</p>
                break;

            default:
                <p class="muted">@(update.Detail ?? "Couldn't determine the latest version.")
                    <a href="@update.Url" target="_blank" rel="noopener noreferrer">Releases ↗</a></p>
                break;
        }
    }
</div>

@code {
    private List<HealthCheck>? checks;
    private bool busy, needsLogin, loggingIn, awaitingAuth, copied, checkingUpdate;
    private string? loginMsg, loginError, verificationUrl, userCode;
    private UpdateInfo? update;

    protected override async Task OnInitializedAsync() => await RunAsync();

    private async Task RunAsync()
    {
        busy = true;
        loginMsg = null;
        loginError = null;
        try
        {
            checks = await Ui.RunHealthAsync();
            needsLogin = checks.Any(c => c.Name == "Authentication" && !c.Ok);
        }
        finally
        {
            busy = false;
        }
    }

    private async Task LoginAsync()
    {
        loggingIn = true;
        loginError = null;
        copied = false;
        try
        {
            var login = await Ui.BeginLoginAsync();
            loginMsg = login.Message;
            verificationUrl = login.VerificationUrl;
            userCode = login.UserCode;
            loggingIn = false;

            if (login.Completion.IsCompletedSuccessfully)
            {
                await RunAsync(); // already signed in (cached token)
                return;
            }

            // Show the code, then wait for the user to authenticate in their browser and
            // auto re-check — or surface the reason sign-in failed.
            awaitingAuth = true;
            StateHasChanged();
            try
            {
                await login.Completion;
                awaitingAuth = false;
                await RunAsync();
            }
            catch (Exception ex)
            {
                awaitingAuth = false;
                loginError = "Sign-in failed: " + ex.Message;
            }
        }
        catch (Exception ex)
        {
            loginMsg = null;
            loginError = ex.Message;
        }
        finally
        {
            loggingIn = false;
        }
    }

    private async Task CopyCode()
    {
        if (string.IsNullOrEmpty(userCode)) return;
        try
        {
            await JS.InvokeVoidAsync("daxterCopy", userCode);
            copied = true;
        }
        catch { /* clipboard unavailable */ }
    }

    private async Task CheckUpdatesAsync()
    {
        checkingUpdate = true;
        update = null;
        try { update = await Version.CheckLatestAsync(); }
        finally { checkingUpdate = false; }
    }

    private string UpgradeCommands()
    {
        var img = $"ghcr.io/{Version.Repo.ToLowerInvariant()}:latest";
        return
            $"docker pull {img}\n" +
            "docker rm -f daxter            # your container name\n" +
            "docker run -d -p 8080:8080 --env-file daxter.env \\\n" +
            "  -v daxter-tokens:/home/daxter/.daxter \\\n" +
            $"  {img} web";
    }
}
