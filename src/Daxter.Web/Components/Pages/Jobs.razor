@page "/jobs"
@inject JobService Svc
@implements IDisposable

<PageTitle>DAXter — Jobs</PageTitle>

<h1>Jobs@(Svc.ActiveCount > 0 ? $" ({Svc.ActiveCount} running)" : "")</h1>
<p class="muted">
    Every refresh — whether launched from this console, the CLI, or an MCP client — runs through one
    shared queue, <strong>one refresh per model at a time</strong> (different models in parallel). The
    <em>Source</em> badge shows which interface queued each job. Click a row for its activity log.
    Launch refreshes from the <a href="refresh">Refresh</a> page.
</p>

@{ var (wState, wAge) = Svc.WorkerStatus(); }
<div class="worker-status worker-@wState">
    <span class="dot">●</span>
    @if (wState == "alive")
    {
        <span>Refresh worker running — queued jobs will execute.</span>
    }
    else if (wState == "stale")
    {
        <span>Refresh worker last seen @((int)(wAge?.TotalSeconds ?? 0))s ago — it may be down; queued jobs won't run until it recovers.</span>
    }
    else
    {
        <span>No refresh worker is running — start the DAXter web container so queued jobs execute.</span>
    }
</div>

@if (!string.IsNullOrEmpty(Qws) && !string.IsNullOrEmpty(Qds))
{
    <p><a class="btn-sm back-btn" href="@($"refresh?ws={Uri.EscapeDataString(Qws!)}&ds={Uri.EscapeDataString(Qds!)}")">← Back to Refresh (@Qds)</a></p>
}

<div class="cmd-group">
    <button class="btn-sm" @onclick="Refresh">Refresh</button>
    <button class="btn-sm" @onclick="ClearFinished" disabled="@(jobs.Count == 0)">Clear finished</button>
    <span class="muted">@Svc.ActiveCount active · @jobs.Count total</span>
</div>

@if (msg is not null) { <p class="bad-text">@msg</p> }

@if (jobs.Count == 0)
{
    <p class="muted">No jobs yet.</p>
}
else
{
    <div class="grid-wrap">
        <table class="grid">
            <thead>
                <tr><th></th><th>#</th><th>Status</th><th>Source</th><th>Job</th><th>Step</th><th>Time / est.</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var j in jobs)
                {
                    <tr class="lvl-@j.Status job-row" @onclick="() => Toggle(j.Id)">
                        <td class="nowrap">@(expanded.Contains(j.Id) ? "▾" : "▸")</td>
                        <td class="nowrap">@j.Id</td>
                        <td><span class="badge badge-job-@j.Status">@j.Status</span></td>
                        <td><span class="badge badge-origin" title="Queued from @j.Origin">@j.Origin</span></td>
                        <td>
                            @j.Title
                            <div class="row-sub">@j.Spec.Workspace · @j.Spec.Dataset</div>
                        </td>
                        <td class="nowrap muted">@(j.Step ?? "")</td>
                        <td class="nowrap">@TimeCell(j)</td>
                        <td @onclick:stopPropagation="true">
                            @if (j.CanCancel)
                            {
                                <button class="btn-sm" @onclick="() => Cancel(j.Id)">Cancel</button>
                            }
                            else
                            {
                                @if (Svc.ResumePreview(j.Id) is { Partial: true } rp)
                                {
                                    <button class="btn-sm" @onclick="() => Resume(j.Id, true)"
                                            title="Re-run only the @rp.Count not-yet-done partition(s)">↻ Resume @rp.Count left</button>
                                    <button class="btn-sm" @onclick="() => Resume(j.Id, false)"
                                            title="Re-run the whole table from scratch">full</button>
                                }
                                else
                                {
                                    <button class="btn-sm" @onclick="() => Resume(j.Id, false)" title="Re-run this refresh">↻ Resume</button>
                                }
                                <button class="btn-sm" @onclick="() => Dismiss(j.Id)" title="Remove from the list">×</button>
                            }
                        </td>
                    </tr>
                    @if (j.Status == JobStatus.Running && j.Progress is { } p)
                    {
                        <tr class="progress-row"><td colspan="8"><div class="pbar"><div class="pbar-fill" style="width:@((int)(p * 100))%"></div></div></td></tr>
                    }
                    @if (expanded.Contains(j.Id))
                    {
                        <tr class="detail-row"><td colspan="8">
                            <div class="job-detail">
                                <div class="muted">@j.Spec.Workspace / @j.Spec.Dataset</div>
                                <ul class="timeline">
                                    @foreach (var e in Svc.EventsOf(j.Id))
                                    {
                                        <li><span class="t">@e.Time.ToString("HH:mm:ss")</span> @e.Message</li>
                                    }
                                </ul>
                                @if (j.Error is not null) { <pre class="code">@j.Error</pre> }
                            </div>
                        </td></tr>
                    }
                }
            </tbody>
        </table>
    </div>
}

@code {
    [Parameter, SupplyParameterFromQuery(Name = "ws")] public string? Qws { get; set; }
    [Parameter, SupplyParameterFromQuery(Name = "ds")] public string? Qds { get; set; }

    private IReadOnlyList<RefreshJob> jobs = Array.Empty<RefreshJob>();
    private readonly HashSet<int> expanded = new();
    private Timer? ticker;

    protected override void OnInitialized()
    {
        Svc.Changed += OnChanged;
        Refresh();
        // Tick once a second so elapsed time / progress update while a job runs, and so jobs queued
        // by the CLI/MCP server (other processes, same shared queue) surface promptly here too.
        ticker = new Timer(_ => InvokeAsync(() => { Refresh(); StateHasChanged(); }),
            null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
    }

    private void Refresh() => jobs = Svc.Snapshot();
    private void ClearFinished() { Svc.ClearFinished(); Refresh(); }
    private string? msg;
    private void Cancel(int id) { Svc.Cancel(id); Refresh(); }
    private void Dismiss(int id) { Svc.Remove(id); Refresh(); }
    private void Resume(int id, bool remainingOnly)
    {
        msg = null;
        try
        {
            var job = Svc.Resume(id, remainingOnly);
            if (job is not null) msg = $"Queued job #{job.Id}: {job.Title}";
        }
        catch (Exception ex) { msg = ex.Message; }
        Refresh();
    }
    private void Toggle(int id) { if (!expanded.Remove(id)) expanded.Add(id); }
    private void OnChanged() => InvokeAsync(() => { Refresh(); StateHasChanged(); });

    private string TimeCell(RefreshJob j)
    {
        var elapsed = j.Duration is { } d ? (d.TotalSeconds < 1 ? "<1s" : $"{(int)d.TotalSeconds}s") : "";
        if (j.Status == JobStatus.Running && j.EstimateSeconds is { } est)
            return $"{elapsed} / ~{(int)est}s";
        if (j.Status == JobStatus.Queued && j.EstimateSeconds is { } e2)
            return $"~{(int)e2}s est.";
        return elapsed;
    }

    public void Dispose()
    {
        Svc.Changed -= OnChanged;
        ticker?.Dispose();
    }
}
