@page "/configure"
@inject ConfigState State

<PageTitle>DAXter — Configure</PageTitle>

<h1>Configure</h1>
<p class="muted">
    Edit the console's settings — changes apply <strong>immediately</strong> to Status/Explore.
    <strong>Save</strong> persists them across restarts (to the mounted <code>~/.daxter</code>
    volume). These drive this web console; for the MCP server, copy the env / snippet below.
</p>

@if (saved is not null) { <p class="ok-text">@saved</p> }

<div class="form">
    <label>Auth mode
        <select @bind="State.AuthMode">
            <option value="device-code">device-code (sign in as yourself)</option>
            <option value="service-principal">service-principal (automation)</option>
        </select>
    </label>
    <label>Tenant id <input @bind="State.TenantId" placeholder="GUID (optional for device-code)" /></label>
    <label>Default workspace <input @bind="State.Workspace" placeholder="optional" /></label>
    <label>Default dataset <input @bind="State.Dataset" placeholder="optional" /></label>
    @if (string.Equals(State.AuthMode, "service-principal", StringComparison.OrdinalIgnoreCase))
    {
        <label>Client id <input @bind="State.ClientId" placeholder="app GUID" /></label>
        <label>Client secret <input @bind="State.ClientSecret" type="password" placeholder="app secret" /></label>
    }
    <label>Prod workspaces (comma-separated) <input @bind="State.ProdWorkspaces" placeholder="e.g. Sales Analytics,Marketing" /></label>
    <label class="checkbox"><input type="checkbox" @bind="State.AllowWrites" /> Allow writes (refresh/cache) over MCP</label>
    <label class="checkbox"><input type="checkbox" @bind="State.AllowModelEdit" /> Allow model edits (measures, parameters, roles, columns, sources, tables) — <strong>irreversible for PBIX download</strong></label>
</div>

<div class="actions">
    <button class="btn" @onclick="DoSave">Save</button>
    <span class="muted">@(State.Persisted ? "✓ persisted to volume" : "from environment (not yet persisted)")</span>
</div>

<h3>Env file</h3>
<pre class="code">@EnvFile()</pre>

<h3>Claude Desktop MCP entry</h3>
<p class="muted">For the MCP server — add under <code>mcpServers</code> in <code>claude_desktop_config.json</code>.</p>
<div class="form"><label>Env file path <input @bind="envPath" placeholder="/absolute/path/to/daxter.env" /></label></div>
<pre class="code">@Snippet()</pre>

@code {
    private string envPath = "/path/to/daxter.env";
    private string? saved;

    private void DoSave()
    {
        try { saved = "Saved ✓ — " + State.Save(); }
        catch (Exception ex) { saved = "Save failed: " + ex.Message; }
    }

    private bool IsSp => string.Equals(State.AuthMode, "service-principal", StringComparison.OrdinalIgnoreCase);

    private string EnvFile()
    {
        var lines = new List<string> { $"DAXTER_AUTH_MODE={State.AuthMode}" };
        if (!string.IsNullOrWhiteSpace(State.TenantId)) lines.Add($"DAXTER_TENANT_ID={State.TenantId}");
        if (IsSp)
        {
            lines.Add($"DAXTER_CLIENT_ID={State.ClientId}");
            lines.Add($"DAXTER_CLIENT_SECRET={State.ClientSecret}");
        }
        if (!string.IsNullOrWhiteSpace(State.Workspace)) lines.Add($"DAXTER_WORKSPACE={State.Workspace}");
        if (!string.IsNullOrWhiteSpace(State.Dataset)) lines.Add($"DAXTER_DATASET={State.Dataset}");
        if (!string.IsNullOrWhiteSpace(State.ProdWorkspaces)) lines.Add($"DAXTER_PROD_WORKSPACES={State.ProdWorkspaces}");
        if (State.AllowWrites) lines.Add("DAXTER_MCP_ALLOW_WRITES=true");
        if (State.AllowModelEdit) lines.Add("DAXTER_MCP_ALLOW_MODEL_EDIT=true");
        return string.Join("\n", lines);
    }

    private string Snippet() =>
        "\"mcpServers\": {\n" +
        "  \"daxter\": {\n" +
        "    \"command\": \"/usr/local/bin/docker\",\n" +
        "    \"args\": [\"run\", \"-i\", \"--rm\",\n" +
        "             \"--env-file\", \"" + envPath + "\",\n" +
        "             \"-v\", \"daxter-tokens:/home/daxter/.daxter\",\n" +
        "             \"ghcr.io/danlugo/daxter:latest\", \"mcp\"]\n" +
        "  }\n" +
        "}";
}
