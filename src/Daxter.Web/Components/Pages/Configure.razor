@page "/configure"
@inject ConfigState State

<PageTitle>DAXter — Configure</PageTitle>

<h1>Configure</h1>
<p class="muted">
    Edit the console's settings — changes apply <strong>immediately</strong> to Status/Explore.
    <strong>Save</strong> persists them across restarts (to the mounted <code>~/.daxter</code>
    volume). These drive this web console; for the MCP server, copy the env / snippet below.
</p>

@if (saved is not null) { <p class="ok-text">@saved</p> }

<div class="form">
    <label>Auth mode
        <select @bind="State.AuthMode">
            <option value="device-code">device-code (sign in as yourself)</option>
            <option value="service-principal">service-principal (automation)</option>
        </select>
    </label>
    <label>Tenant id <input @bind="State.TenantId" placeholder="GUID (optional for device-code)" /></label>
    <label>Default workspace <input @bind="State.Workspace" placeholder="optional" /></label>
    <label>Default dataset <input @bind="State.Dataset" placeholder="optional" /></label>
    @if (string.Equals(State.AuthMode, "service-principal", StringComparison.OrdinalIgnoreCase))
    {
        <label>Client id <input @bind="State.ClientId" placeholder="app GUID" /></label>
        <label>Client secret <input @bind="State.ClientSecret" type="password" placeholder="app secret" /></label>
    }
    <fieldset class="ws-gate">
        <legend>Workspace write protection</legend>
        <p class="muted">
            Even with <strong>Allow writes</strong> on, the gate below decides which workspaces can actually be mutated
            (refresh, cache clear, model edits, bindings, copy-job / notebook runs). Patterns use <code>*</code> as a
            wildcard (zero or more chars), are case-insensitive, and match the whole workspace name —
            <code>Data*Dev</code>, <code>*QA</code>, <code>*Prod*</code>.
            <strong>Deny wins; allow-list restricts further when set.</strong>
        </p>
        <label>
            <span>Read-only workspaces <small class="muted">— deny-list (comma-separated patterns)</small></span>
            <input @bind="State.ReadOnlyWorkspaces" placeholder="e.g. *Prod*, Data Hub, Reporting*" />
        </label>
        <label>
            <span>Write-allowed workspaces <small class="muted">— allow-list; when set, only these can be mutated</small></span>
            <input @bind="State.WriteWorkspaces" placeholder="e.g. Data*Dev, *QA, Sandbox*" />
        </label>
        @if (!string.IsNullOrWhiteSpace(State.ProdWorkspaces))
        {
            <label>
                <span>Legacy prod workspaces <small class="muted">— treated as additional read-only patterns; phase out into the field above</small></span>
                <input @bind="State.ProdWorkspaces" placeholder="(legacy)" />
            </label>
        }
        @if (!string.IsNullOrWhiteSpace(State.Workspace))
        {
            <p class="muted gate-preview">
                Default workspace <code>@State.Workspace</code> →
                @if (CurrentIsReadOnly())
                {
                    <strong class="bad-text">READ-ONLY</strong>
                    <span> · @(CurrentReadOnlyReason() ?? "matched a rule")</span>
                }
                else
                {
                    <strong class="ok-text">writable</strong>
                    <span> (subject to <em>Allow writes</em>)</span>
                }
            </p>
        }
    </fieldset>
    @if (State.ReadOnly)
    {
        <div class="card bad">
            <p class="bad-text"><strong>Read-only mode is ON</strong> (<code>DAXTER_READONLY</code>).</p>
            <p class="muted">Every mutation is disabled and these toggles are overridden — model edits, schedule changes, cache clear, SQL writes, and gateway/ownership changes are all blocked. <strong>Refreshes still run</strong> (subject to the Production-workspace rules). Unset <code>DAXTER_READONLY</code> to lift the lock.</p>
        </div>
    }
    <label class="checkbox"><input type="checkbox" @bind="State.AllowWrites" disabled="@State.ReadOnly" /> Allow writes (refresh/cache) over MCP</label>
    <label class="checkbox"><input type="checkbox" @bind="State.AllowModelEdit" disabled="@State.ReadOnly" /> Allow model edits (measures, parameters, roles, columns, sources, tables) — <strong>irreversible for PBIX download</strong></label>
</div>

<div class="actions">
    <button class="btn" @onclick="DoSave">Save</button>
    <span class="muted">@(State.Persisted ? "✓ persisted to volume" : "from environment (not yet persisted)")</span>
</div>

<h3>Env file</h3>
<pre class="code">@EnvFile()</pre>

<h3>Claude Desktop MCP entry</h3>
<p class="muted">For the MCP server — add under <code>mcpServers</code> in <code>claude_desktop_config.json</code>.</p>
<div class="form"><label>Env file path <input @bind="envPath" placeholder="/absolute/path/to/daxter.env" /></label></div>
<pre class="code">@Snippet()</pre>

@code {
    private string envPath = "/path/to/daxter.env";
    private string? saved;

    private void DoSave()
    {
        try { saved = "Saved ✓ — " + State.Save(); }
        catch (Exception ex) { saved = "Save failed: " + ex.Message; }
    }

    private bool IsSp => string.Equals(State.AuthMode, "service-principal", StringComparison.OrdinalIgnoreCase);

    /// <summary>Evaluate the gate against the default workspace right now — the live preview tells
    /// the user whether their current patterns lock or unlock it before they save.</summary>
    private bool CurrentIsReadOnly() => State.ToConfig(State.Workspace, State.Dataset).IsReadOnlyTarget();

    /// <summary>Which rule caused the current workspace to be read-only (if any).</summary>
    private string? CurrentReadOnlyReason() => State.ToConfig(State.Workspace, State.Dataset).ReadOnlyReason();

    private string EnvFile()
    {
        var lines = new List<string> { $"DAXTER_AUTH_MODE={State.AuthMode}" };
        if (!string.IsNullOrWhiteSpace(State.TenantId)) lines.Add($"DAXTER_TENANT_ID={State.TenantId}");
        if (IsSp)
        {
            lines.Add($"DAXTER_CLIENT_ID={State.ClientId}");
            lines.Add($"DAXTER_CLIENT_SECRET={State.ClientSecret}");
        }
        if (!string.IsNullOrWhiteSpace(State.Workspace)) lines.Add($"DAXTER_WORKSPACE={State.Workspace}");
        if (!string.IsNullOrWhiteSpace(State.Dataset)) lines.Add($"DAXTER_DATASET={State.Dataset}");
        if (!string.IsNullOrWhiteSpace(State.ProdWorkspaces)) lines.Add($"DAXTER_PROD_WORKSPACES={State.ProdWorkspaces}");
        if (!string.IsNullOrWhiteSpace(State.ReadOnlyWorkspaces)) lines.Add($"DAXTER_READONLY_WORKSPACES={State.ReadOnlyWorkspaces}");
        if (!string.IsNullOrWhiteSpace(State.WriteWorkspaces)) lines.Add($"DAXTER_WRITE_WORKSPACES={State.WriteWorkspaces}");
        if (State.AllowWrites) lines.Add("DAXTER_MCP_ALLOW_WRITES=true");
        if (State.AllowModelEdit) lines.Add("DAXTER_MCP_ALLOW_MODEL_EDIT=true");
        return string.Join("\n", lines);
    }

    private string Snippet() =>
        "\"mcpServers\": {\n" +
        "  \"daxter\": {\n" +
        "    \"command\": \"/usr/local/bin/docker\",\n" +
        "    \"args\": [\"run\", \"-i\", \"--rm\",\n" +
        "             \"--env-file\", \"" + envPath + "\",\n" +
        "             \"-v\", \"daxter-tokens:/home/daxter/.daxter\",\n" +
        "             \"ghcr.io/danlugo/daxter:latest\", \"mcp\"]\n" +
        "  }\n" +
        "}";
}
