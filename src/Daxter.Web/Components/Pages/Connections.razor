@page "/connections"
@inject DaxterUi Ui
@inject UsageStore Usage
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject UiBusy BusyState

<PageTitle>DAXter — Connections</PageTitle>

<button class="btn-sm back-btn" @onclick="GoBack" title="Back to the previous page">← Back</button>
<h1>Connections &amp; ownership</h1>
<p class="muted">
    Take over a model and see how its data sources <em>map to</em> connections — like the Power BI
    <em>Gateway and cloud connections</em> screen. The current mapping (cloud / on-prem / VNet gateway,
    with names) is read from the Fabric API and needs only model access. To <strong>change</strong> a
    binding you can re-bind every gateway source to a single gateway you administer (the public API binds
    one gateway per model); cloud-connection "Maps to" is set in the Service and has no public write API.
</p>

@if (!Ui.WritesEnabled)
{
    <div class="worker-status worker-none">
        <span class="dot">●</span>
        <span>Writes are <strong>off</strong> — enable <a href="configure">⚙ Configure → Allow writes</a> to take over or
            bind. You can still view current connections below.</span>
    </div>
}

<div class="cmd-group">
    <label>Workspace
        <select @bind="workspace" @bind:after="OnWorkspaceChanged">
            <option value="">— pick a workspace —</option>
            @foreach (var w in workspaces) { <option value="@w">@w</option> }
        </select>
    </label>
    <label>Dataset
        <select @bind="dataset" @bind:after="OnDatasetChanged" disabled="@(string.IsNullOrEmpty(workspace))">
            <option value="">— pick a model —</option>
            @foreach (var d in datasets) { <option value="@d">@d</option> }
        </select>
    </label>
</div>

@if (!string.IsNullOrEmpty(dataset))
{
    <div class="card">
        <div class="cmd-group conn-owner">
            <button class="btn" @onclick="AskTakeOver" disabled="@(!Ui.WritesEnabled || busy)">Take over</button>
            <span class="muted">Owner: <strong>@(string.IsNullOrEmpty(owner) ? "—" : owner)</strong></span>
            <button class="btn-sm" @onclick="LoadAll" disabled="@busy" title="Reload">↻</button>
        </div>

        <div class="conn-head">Gateway and cloud connections</div>

        @* ---- current mapping (rich read: name + connectivity, from the Fabric API) ---- *@
        @if (itemConns is null && datasources is null)
        {
            <p class="muted">Loading connections…</p>
        }
        else if (itemConns is not null && itemConns.RowCount > 0)
        {
            <div class="grid-wrap">
                <table class="grid">
                    <thead>
                        <tr><th>Connection</th><th>Connectivity</th><th>Type</th><th>Maps to (source)</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var row in itemConns.Rows)
                        {
                            <tr>
                                <td>@Cell(itemConns, row, "displayName")</td>
                                <td>@Connectivity(Cell(itemConns, row, "connectivityType"))</td>
                                <td>@Cell(itemConns, row, "type")</td>
                                <td class="nowrap">@Cell(itemConns, row, "path")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else if (datasources is not null && datasources.RowCount > 0)
        {
            <p class="muted">Connection names unavailable (Fabric API) — showing raw data sources:</p>
            <div class="conn-list">
                @foreach (var row in datasources.Rows)
                {
                    <div class="conn-row">
                        <div class="conn-src">
                            <strong>@SourceLabel(row)</strong>
                            <br /><small class="muted">current: @BoundLabel(row)</small>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="muted">No connections reported for this model.</p>
        }

        @* ---- re-bind to a gateway (the one writable change) ---- *@
        @if (datasources is not null && datasources.RowCount > 0)
        {
            <div class="conn-head">Re-bind to a gateway</div>
            <div class="cmd-group">
                <label>Gateway
                    <select @bind="bindGateway" @bind:after="OnBindGatewayChanged" disabled="@busy">
                        <option value="">— pick a gateway you administer —</option>
                        @if (gateways is not null)
                        {
                            @foreach (var gw in gateways.Rows)
                            {
                                <option value="@Cell(gateways, gw, "id")">@Cell(gateways, gw, "name") (@Cell(gateways, gw, "type"))</option>
                            }
                        }
                    </select>
                </label>
            </div>

            @if (gateways is not null && gateways.RowCount == 0)
            {
                <p class="muted">No gateways are visible to this account — re-binding needs a <strong>role</strong>
                    (admin / data-source user) on the gateway. The current mapping above still shows where each
                    source is bound, even on gateways you can't manage.</p>
            }

            @if (!string.IsNullOrEmpty(bindGateway))
            {
                <div class="conn-list">
                    @for (var i = 0; i < datasources.Rows.Count; i++)
                    {
                        var row = datasources.Rows[i];
                        var ix = i;
                        var matches = gwConns is null ? null : ExactConns(gwConns, row);
                        <div class="conn-row">
                            <div class="conn-src"><strong>@SourceLabel(row)</strong></div>
                            <div class="conn-mapsto">
                                <span class="conn-lbl">maps to:</span>
                                <label class="conn-fld">connection
                                    <select value="@rowConn.GetValueOrDefault(ix, "")" @onchange="e => SetRowConn(ix, e)"
                                            disabled="@(busy || matches is null || matches.Count == 0)">
                                        <option value="">— first matching —</option>
                                        @if (matches is not null)
                                        {
                                            @foreach (var g in matches)
                                            {
                                                <option value="@Cell(gwConns!, g, "id")">@GwConnLabel(gwConns!, g)</option>
                                            }
                                        }
                                    </select>
                                </label>
                                @if (matches is not null && matches.Count == 0)
                                {
                                    <span class="muted conn-filtered">no matching connection on this gateway</span>
                                }
                            </div>
                        </div>
                    }
                </div>
                <div class="cmd-group">
                    <button class="btn" @onclick="AskBind" disabled="@(!Ui.WritesEnabled || busy)">Apply</button>
                </div>
            }

            <p class="muted">
                Re-bind maps every matching source to the <strong>one</strong> gateway selected above
                (the public <em>BindToGateway</em> API is one gateway per model). The shareable
                <strong>cloud-connection</strong> "Maps to" and per-source <em>different</em> gateways are
                set in the Power BI Service (<em>Settings → Gateway and cloud connections</em>) — no public API.
            </p>
        }
    </div>
}

@if (!string.IsNullOrEmpty(result))
{
    <pre class="code @(resultOk ? "" : "bad-text")">@result</pre>
}

@if (pendingAction is not null)
{
    <div class="modal-overlay" @onclick="CancelConfirm">
        <div class="modal" @onclick:stopPropagation="true">
            <h3>Confirm</h3>
            <p>@pendingText</p>
            <p class="muted">This writes to the Power BI Service.</p>
            <div class="cmd-group">
                <button class="btn" @onclick="DoConfirm" disabled="@busy">✓ Confirm</button>
                <button class="btn-sm" @onclick="CancelConfirm" disabled="@busy">Cancel</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter, SupplyParameterFromQuery(Name = "ws")] public string? Qws { get; set; }
    [Parameter, SupplyParameterFromQuery(Name = "ds")] public string? Qds { get; set; }

    private List<string> workspaces = new();
    private List<string> datasets = new();
    private string workspace = "";
    private string dataset = "";

    private QueryResult? datasetsResult;   // kept to look up the owner (configuredBy)
    private string? owner;

    private QueryResult? itemConns;        // rich current mapping (Fabric List Item Connections)
    private QueryResult? datasources;      // the model's data sources (bind matching + fallback display)
    private QueryResult? gateways;         // gateways the account administers (the re-bind picker)

    // Re-bind state: the single chosen gateway, its connections, and per-source chosen connection.
    private string bindGateway = "";
    private QueryResult? gwConns;
    private readonly Dictionary<int, string> rowConn = new();

    private string? result;
    private bool resultOk;
    private bool busy;

    private Func<Task>? pendingAction;
    private string? pendingText;

    protected override async Task OnInitializedAsync()
        => workspaces = Names(await Ui.WorkspacesAsync());

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(Qws)) return;
        if (Qws == workspace && (Qds ?? "") == dataset) return;
        await Busy(async () =>
        {
            if (workspaces.Count == 0) workspaces = Names(await Ui.WorkspacesAsync());
            workspace = Qws!;
            datasetsResult = await Ui.DatasetsAsync(workspace);
            datasets = Names(datasetsResult);
            dataset = Qds ?? "";
            ResetModel();
            if (!string.IsNullOrEmpty(dataset)) await LoadAllCore();
        });
    }

    private async Task OnWorkspaceChanged()
    {
        dataset = ""; datasets = new(); datasetsResult = null; ResetModel();
        if (string.IsNullOrEmpty(workspace)) return;
        await Busy(async () =>
        {
            datasetsResult = await Ui.DatasetsAsync(workspace);
            datasets = Names(datasetsResult);
        });
        Usage.Record(UsageStore.Workspace, workspace, null, UsageStore.ConnectionsContext);
    }

    private async Task OnDatasetChanged()
    {
        ResetModel();
        if (string.IsNullOrEmpty(dataset)) return;
        Usage.Record(UsageStore.Dataset, dataset, workspace, UsageStore.ConnectionsContext);
        await LoadAll();
    }

    private void ResetModel()
    {
        itemConns = datasources = gateways = gwConns = null;
        bindGateway = ""; rowConn.Clear(); owner = null; result = null;
    }

    private Task LoadAll() => Busy(LoadAllCore);

    private async Task LoadAllCore()
    {
        owner = LookupOwner(dataset);
        // Rich current mapping (names + connectivity) — needs only model access, so it can name
        // bindings to gateways the caller can't manage. Null when the Fabric API is unreachable.
        itemConns = await Ui.ItemConnectionsAsync(workspace, dataset);
        // Raw data sources — drive the re-bind matching and the fallback display.
        datasources = await Ui.DatasourcesAsync(workspace, dataset);
        // Gateways the account administers — the only ones a re-bind can target.
        gateways = await Ui.GatewaysAsync();
        bindGateway = ""; gwConns = null; rowConn.Clear();
    }

    private async Task OnBindGatewayChanged()
    {
        rowConn.Clear(); gwConns = null;
        if (string.IsNullOrEmpty(bindGateway)) return;
        await Busy(async () => gwConns = await Ui.GatewayDatasourcesAsync(bindGateway));
    }

    private void SetRowConn(int i, ChangeEventArgs e)
    {
        var v = e.Value?.ToString() ?? "";
        if (string.IsNullOrEmpty(v)) rowConn.Remove(i); else rowConn[i] = v;
    }

    private void AskTakeOver()
    {
        pendingText = $"Take over ownership of '{dataset}' in '{workspace}'? You become the model owner.";
        pendingAction = () => Run(() => Ui.TakeOverAsync(workspace, dataset));
    }

    private void AskBind()
    {
        if (string.IsNullOrEmpty(bindGateway))
        {
            result = "Pick a gateway to re-bind to first."; resultOk = false; pendingAction = null; return;
        }
        var ids = rowConn.Values.Where(v => !string.IsNullOrEmpty(v)).Distinct().ToList();
        pendingText = $"Bind '{dataset}' to gateway {bindGateway}"
            + (ids.Count > 0 ? $", mapping {ids.Count} connection(s)?" : " (auto-map matching sources)?");
        pendingAction = () => Run(() => Ui.BindToGatewayAsync(workspace, dataset, bindGateway, ids.Count > 0 ? ids : null));
    }

    private async Task DoConfirm()
    {
        var act = pendingAction!;
        pendingAction = null; pendingText = null;
        await act();
    }

    private void CancelConfirm() { pendingAction = null; pendingText = null; }

    private async Task Run(Func<Task<string>> op)
    {
        busy = true; result = null;
        try
        {
            await BusyState.Run(async () =>
            {
                result = await op();
                resultOk = true;
                await LoadAllCore();
            });
        }
        catch (Exception ex) { result = ex.Message; resultOk = false; }
        finally { busy = false; }
    }

    private Task Busy(Func<Task> work) => BusyState.Run(async () =>
    {
        busy = true;
        try { await work(); }
        catch (Exception ex) { result = ex.Message; resultOk = false; }
        finally { busy = false; }
    });

    private async Task GoBack() => await JS.InvokeVoidAsync("history.back");

    // ---- presentation helpers ----

    private string? LookupOwner(string name)
    {
        if (datasetsResult is null) return null;
        foreach (var row in datasetsResult.Rows)
            if (string.Equals(Cell(datasetsResult, row, "name"), name, StringComparison.OrdinalIgnoreCase))
            {
                var by = Cell(datasetsResult, row, "configuredBy");
                return string.IsNullOrEmpty(by) ? null : by;
            }
        return null;
    }

    /// <summary>Friendly label for the Fabric connectivityType enum.</summary>
    private static string Connectivity(string raw) => raw switch
    {
        "ShareableCloud" => "Cloud",
        "Automatic" => "Cloud (automatic)",
        "VirtualNetworkGateway" => "VNet gateway",
        "OnPremisesGateway" => "On-prem gateway",
        "OnPremisesGatewayPersonal" => "Personal gateway",
        "" or "None" => "—",
        _ => raw,
    };

    private string SourceLabel(object?[] row)
    {
        var type = Cell(datasources!, row, "datasourceType");
        var server = Cell(datasources!, row, "server");
        var db = Cell(datasources!, row, "database");
        var pathOrUrl = Cell(datasources!, row, "path");
        if (string.IsNullOrEmpty(pathOrUrl)) pathOrUrl = Cell(datasources!, row, "url");
        var detail = !string.IsNullOrEmpty(server)
            ? (string.IsNullOrEmpty(db) ? server : $"{server} / {db}")
            : pathOrUrl;
        return string.IsNullOrEmpty(detail) ? type : $"{type} — {detail}";
    }

    private string BoundLabel(object?[] row)
    {
        var gw = Cell(datasources!, row, "gatewayId");
        return string.IsNullOrEmpty(gw) ? "cloud / SSO (no gateway)" : $"gateway {gw}";
    }

    /// <summary>Gateway connections that EXACTLY match a source — same type and same server+database
    /// (normalized). No fallback: if none match, the source has no connection on this gateway.</summary>
    private List<object?[]> ExactConns(QueryResult conns, object?[] sourceRow)
    {
        string Norm(string s) => s.Trim().ToLowerInvariant();
        var srcType = Norm(Cell(datasources!, sourceRow, "datasourceType"));
        var srcServer = Norm(Cell(datasources!, sourceRow, "server"));
        var srcDb = Norm(Cell(datasources!, sourceRow, "database"));
        bool Matches(object?[] g)
        {
            var t = Norm(Cell(conns, g, "datasourceType"));
            var s = Norm(Cell(conns, g, "server"));
            var d = Norm(Cell(conns, g, "database"));
            if (srcType.Length > 0 && t.Length > 0 && t != srcType) return false;
            if (srcServer.Length > 0 && s != srcServer) return false;
            if (srcDb.Length > 0 && d != srcDb) return false;
            return s.Length > 0 || d.Length > 0;   // require at least an identity match, not type-only
        }
        return conns.Rows.Where(Matches).ToList();
    }

    private static string GwConnLabel(QueryResult r, object?[] g)
    {
        var name = Cell(r, g, "datasourceName");
        var type = Cell(r, g, "datasourceType");
        var server = Cell(r, g, "server");
        var db = Cell(r, g, "database");
        var detail = string.IsNullOrEmpty(server) ? type : (string.IsNullOrEmpty(db) ? server : $"{server}/{db}");
        return string.IsNullOrEmpty(name) ? detail : $"{name} — {detail}";
    }

    private static List<string> Names(QueryResult r)
    {
        var idx = 0;
        for (var i = 0; i < r.Columns.Count; i++)
            if (string.Equals(r.Columns[i], "Name", StringComparison.OrdinalIgnoreCase)) { idx = i; break; }
        return r.Rows.Select(row => idx < row.Length ? row[idx]?.ToString() ?? "" : "")
            .Where(s => s.Length > 0)
            .OrderBy(s => s, StringComparer.OrdinalIgnoreCase)   // picker lists are sorted A→Z
            .ToList();
    }

    private static string Cell(QueryResult r, object?[] row, string col)
    {
        for (var i = 0; i < r.Columns.Count; i++)
            if (string.Equals(r.Columns[i], col, StringComparison.OrdinalIgnoreCase))
                return i < row.Length ? row[i]?.ToString() ?? "" : "";
        return "";
    }
}
