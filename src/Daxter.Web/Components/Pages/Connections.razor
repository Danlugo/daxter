@page "/connections"
@inject DaxterUi Ui
@inject UsageStore Usage
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject UiBusy BusyState

<PageTitle>DAXter — Connections</PageTitle>

<button class="btn-sm back-btn" @onclick="GoBack" title="Back to the previous page">← Back</button>
<h1>Connections &amp; ownership</h1>
<p class="muted">
    Take over a model and map its data sources to connections — like the Power BI <em>Gateway and cloud
    connections</em> screen. <strong>Gateway connections</strong> are writable here (pick a gateway, map each
    source, Apply — the public <em>BindToGateway</em> API). <strong>Cloud connections</strong> are read-only:
    a source's cloud "Maps to" has no public write API, so use the Service link to change it.
</p>

@if (!Ui.WritesEnabled)
{
    <div class="worker-status worker-none">
        <span class="dot">●</span>
        <span>Writes are <strong>off</strong> — enable <a href="configure">⚙ Configure → Allow writes</a> to take over or
            bind a gateway. You can still view all mappings below.</span>
    </div>
}

<div class="cmd-group">
    <label>Workspace
        <select @bind="workspace" @bind:after="OnWorkspaceChanged">
            <option value="">— pick a workspace —</option>
            @foreach (var w in workspaces) { <option value="@w">@w</option> }
        </select>
    </label>
    <label>Dataset
        <select @bind="dataset" @bind:after="OnDatasetChanged" disabled="@(string.IsNullOrEmpty(workspace))">
            <option value="">— pick a model —</option>
            @foreach (var d in datasets) { <option value="@d">@d</option> }
        </select>
    </label>
</div>

@if (!string.IsNullOrEmpty(dataset))
{
    <div class="card">
        <div class="cmd-group conn-owner">
            <button class="btn" @onclick="AskTakeOver" disabled="@(!Ui.WritesEnabled || busy)">Take over</button>
            <span class="muted">Owner: <strong>@(string.IsNullOrEmpty(owner) ? "—" : owner)</strong></span>
            <button class="btn-sm" @onclick="LoadAll" disabled="@busy" title="Reload">↻</button>
        </div>

        <div class="conn-head">Gateway and cloud connections</div>

        @if (loading)
        {
            <p class="muted">Loading connections…</p>
        }
        else if (bindSources.Count == 0)
        {
            <p class="muted">No data sources reported for this model.</p>
        }
        else
        {
            @* ============ Gateway connections (writable via BindToGateway) ============ *@
            <h3 class="conn-section">Gateway connections</h3>
            <div class="cmd-group">
                <label>Gateway
                    <select @bind="bindGateway" @bind:after="OnBindGatewayChanged" disabled="@busy">
                        <option value="">— pick a gateway you administer —</option>
                        @if (gateways is not null)
                        {
                            @foreach (var gw in gateways.Rows)
                            {
                                <option value="@Cell(gateways, gw, "id")">@Cell(gateways, gw, "name") (@Cell(gateways, gw, "type"))</option>
                            }
                        }
                    </select>
                </label>
            </div>

            @if (gateways is not null && gateways.RowCount == 0)
            {
                <p class="muted">No gateways are visible to this account — binding needs a <strong>role</strong>
                    (admin / data-source user) on the gateway. The mappings below still show where each source
                    is bound, even on gateways you can't manage.</p>
            }

            @if (!string.IsNullOrEmpty(bindGateway))
            {
                <p class="muted conn-subhead">Data sources included in this semantic model:</p>
                <div class="conn-list">
                    @for (var i = 0; i < bindSources.Count; i++)
                    {
                        var src = bindSources[i];
                        var ix = i;
                        var matches = gwConns is null ? new() : MatchGwConns(gwConns, src);
                        <div class="conn-row">
                            <div class="conn-src">
                                <span class="conn-status @(matches.Count > 0 ? "ok" : "bad")">@(matches.Count > 0 ? "✓" : "✗")</span>
                                <strong>@src.Label</strong>
                                <br /><small class="muted">currently: @CurrentMap(src)</small>
                            </div>
                            <div class="conn-mapsto">
                                <span class="conn-lbl">maps to:</span>
                                <label class="conn-fld">
                                    <select value="@rowConn.GetValueOrDefault(ix, "")" @onchange="e => SetRowConn(ix, e)"
                                            disabled="@(busy || matches.Count == 0)">
                                        <option value="">— none —</option>
                                        @foreach (var g in matches)
                                        {
                                            <option value="@Cell(gwConns!, g, "id")">@GwConnLabel(gwConns!, g)</option>
                                        }
                                    </select>
                                </label>
                                @if (matches.Count == 0)
                                {
                                    <span class="muted conn-filtered">no matching connection on this gateway</span>
                                }
                            </div>
                        </div>
                    }
                </div>
                <div class="cmd-group">
                    <button class="btn" @onclick="AskBind" disabled="@(!Ui.WritesEnabled || busy)">Apply</button>
                </div>
            }
            <p class="muted">
                Apply binds the model to the <strong>one</strong> selected gateway, mapping each ✓ source to the
                chosen connection (public <em>BindToGateway</em>). Cloud-only sources (✗ here) belong in the Cloud
                connections section below.
            </p>

            @* ============ Cloud connections (read-only — Service-only write) ============ *@
            <h3 class="conn-section">Cloud connections</h3>
            <p class="muted conn-subhead">Data sources included in this semantic model:</p>
            <div class="conn-list">
                @for (var i = 0; i < bindSources.Count; i++)
                {
                    var src = bindSources[i];
                    var cmatches = MatchCloudConns(src);
                    <div class="conn-row">
                        <div class="conn-src">
                            <strong>@src.Label</strong>
                            <br /><small class="muted">currently: @CurrentMap(src)</small>
                        </div>
                        <div class="conn-mapsto">
                            <span class="conn-lbl">maps to:</span>
                            <label class="conn-fld">
                                <select value="@cloudPick.GetValueOrDefault(i, "")" disabled="@busy"
                                        title="Read-only — change in the Power BI Service (no public write API)">
                                    <option value="">— none —</option>
                                    @foreach (var c in cmatches)
                                    {
                                        <option value="@Cell(cloudConns!, c, "id")">@CloudConnLabel(cloudConns!, c)</option>
                                    }
                                </select>
                            </label>
                            @if (cmatches.Count == 0)
                            {
                                <span class="muted conn-filtered">no matching cloud connection</span>
                            }
                        </div>
                    </div>
                }
            </div>
            <p class="muted">
                Cloud "Maps to" is <strong>read-only</strong> — there is no public API to set it.
                @if (!string.IsNullOrEmpty(settingsUrl))
                {
                    <a href="@settingsUrl" target="_blank" rel="noopener">Manage in Power BI Service ↗</a>
                }
                else
                {
                    <text>Set it in the Service: <em>Settings → Gateway and cloud connections</em>.</text>
                }
            </p>
        }
    </div>
}

@if (!string.IsNullOrEmpty(result))
{
    <pre class="code @(resultOk ? "" : "bad-text")">@result</pre>
}

@if (pendingAction is not null)
{
    <div class="modal-overlay" @onclick="CancelConfirm">
        <div class="modal" @onclick:stopPropagation="true">
            <h3>Confirm</h3>
            <p>@pendingText</p>
            <p class="muted">This writes to the Power BI Service.</p>
            <div class="cmd-group">
                <button class="btn" @onclick="DoConfirm" disabled="@busy">✓ Confirm</button>
                <button class="btn-sm" @onclick="CancelConfirm" disabled="@busy">Cancel</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter, SupplyParameterFromQuery(Name = "ws")] public string? Qws { get; set; }
    [Parameter, SupplyParameterFromQuery(Name = "ds")] public string? Qds { get; set; }

    private List<string> workspaces = new();
    private List<string> datasets = new();
    private string workspace = "";
    private string dataset = "";

    private QueryResult? datasetsResult;   // kept to look up the owner (configuredBy)
    private string? owner;

    private QueryResult? itemConns;        // rich current mapping (Fabric List Item Connections)
    private QueryResult? datasources;      // the model's data sources (matching + fallback)
    private QueryResult? gateways;         // gateways the account administers (the gateway picker)
    private QueryResult? cloudConns;       // all connections the account can access (for cloud options)
    private string? settingsUrl;           // deep link to the model's Service settings (cloud "Maps to")
    private bool loading;

    // Gateway-bind state: the chosen gateway, its connections, and per-source chosen connection.
    private string bindGateway = "";
    private QueryResult? gwConns;
    private readonly Dictionary<int, string> rowConn = new();
    // Cloud section: per-source current cloud connection (display-only — no public write API).
    private readonly Dictionary<int, string> cloudPick = new();

    // The model's sources unified for matching (named when the Fabric read is available).
    private record BindSource(string Label, string Name, string Type, string Server, string Db, string Connectivity);
    private List<BindSource> bindSources = new();

    private string? result;
    private bool resultOk;
    private bool busy;

    private Func<Task>? pendingAction;
    private string? pendingText;

    protected override async Task OnInitializedAsync()
    {
        workspaces = Names(await Ui.WorkspacesAsync());
        cloudConns = await Ui.ConnectionsAsync();   // tenant-wide; cloud options for the Cloud section
    }

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(Qws)) return;
        if (Qws == workspace && (Qds ?? "") == dataset) return;
        await Busy(async () =>
        {
            if (workspaces.Count == 0) workspaces = Names(await Ui.WorkspacesAsync());
            workspace = Qws!;
            datasetsResult = await Ui.DatasetsAsync(workspace);
            datasets = Names(datasetsResult);
            dataset = Qds ?? "";
            ResetModel();
            if (!string.IsNullOrEmpty(dataset)) await LoadAllCore();
        });
    }

    private async Task OnWorkspaceChanged()
    {
        dataset = ""; datasets = new(); datasetsResult = null; ResetModel();
        if (string.IsNullOrEmpty(workspace)) return;
        await Busy(async () =>
        {
            datasetsResult = await Ui.DatasetsAsync(workspace);
            datasets = Names(datasetsResult);
        });
        Usage.Record(UsageStore.Workspace, workspace, null, UsageStore.ConnectionsContext);
    }

    private async Task OnDatasetChanged()
    {
        ResetModel();
        if (string.IsNullOrEmpty(dataset)) return;
        Usage.Record(UsageStore.Dataset, dataset, workspace, UsageStore.ConnectionsContext);
        await LoadAll();
    }

    private void ResetModel()
    {
        itemConns = datasources = gateways = gwConns = null;
        bindGateway = ""; settingsUrl = null; rowConn.Clear(); cloudPick.Clear();
        bindSources = new(); owner = null; result = null;
    }

    private Task LoadAll() => Busy(LoadAllCore);

    private async Task LoadAllCore()
    {
        loading = true;
        try
        {
            owner = LookupOwner(dataset);
            // Rich current mapping (names + connectivity) — needs only model access.
            itemConns = await Ui.ItemConnectionsAsync(workspace, dataset);
            // Raw data sources — fallback when the Fabric read is unavailable.
            datasources = await Ui.DatasourcesAsync(workspace, dataset);
            // Gateways the account administers — the only ones a bind can target.
            gateways = await Ui.GatewaysAsync();
            settingsUrl = await Ui.ModelSettingsUrlAsync(workspace, dataset);
            bindSources = BuildBindSources();
            BuildCloudPicks();
            // Pre-select the first administered gateway (like the Service shows one selected).
            bindGateway = gateways is { RowCount: > 0 } ? Cell(gateways, gateways.Rows[0], "id") : "";
            gwConns = null; rowConn.Clear();
            if (!string.IsNullOrEmpty(bindGateway)) await SelectGatewayCore();
        }
        finally { loading = false; }
    }

    private Task OnBindGatewayChanged() => Busy(SelectGatewayCore);

    private async Task SelectGatewayCore()
    {
        rowConn.Clear(); gwConns = null;
        if (string.IsNullOrEmpty(bindGateway)) return;
        gwConns = await Ui.GatewayDatasourcesAsync(bindGateway);
        // Pre-select each source's current connection on this gateway (name match), like the Service.
        for (var i = 0; i < bindSources.Count; i++)
        {
            var m = MatchGwConns(gwConns, bindSources[i]);
            var cur = m.FirstOrDefault(g =>
                string.Equals(Cell(gwConns, g, "datasourceName"), bindSources[i].Name, StringComparison.OrdinalIgnoreCase));
            if (cur is not null) rowConn[i] = Cell(gwConns, cur, "id");
        }
    }

    private void SetRowConn(int i, ChangeEventArgs e)
    {
        var v = e.Value?.ToString() ?? "";
        if (string.IsNullOrEmpty(v)) rowConn.Remove(i); else rowConn[i] = v;
    }

    private void AskTakeOver()
    {
        pendingText = $"Take over ownership of '{dataset}' in '{workspace}'? You become the model owner.";
        pendingAction = () => Run(() => Ui.TakeOverAsync(workspace, dataset));
    }

    private void AskBind()
    {
        if (string.IsNullOrEmpty(bindGateway))
        {
            result = "Pick a gateway to bind to first."; resultOk = false; pendingAction = null; return;
        }
        var ids = rowConn.Values.Where(v => !string.IsNullOrEmpty(v)).Distinct().ToList();
        if (ids.Count == 0)
        {
            result = "No source maps to a connection on this gateway — nothing to bind."; resultOk = false; pendingAction = null; return;
        }
        pendingText = $"Bind '{dataset}' to gateway {bindGateway}, mapping {ids.Count} connection(s)?";
        pendingAction = () => Run(() => Ui.BindToGatewayAsync(workspace, dataset, bindGateway, ids));
    }

    private async Task DoConfirm()
    {
        var act = pendingAction!;
        pendingAction = null; pendingText = null;
        await act();
    }

    private void CancelConfirm() { pendingAction = null; pendingText = null; }

    private async Task Run(Func<Task<string>> op)
    {
        busy = true; result = null;
        try
        {
            await BusyState.Run(async () =>
            {
                result = await op();
                resultOk = true;
                await LoadAllCore();
            });
        }
        catch (Exception ex) { result = ex.Message; resultOk = false; }
        finally { busy = false; }
    }

    private Task Busy(Func<Task> work) => BusyState.Run(async () =>
    {
        busy = true;
        try { await work(); }
        catch (Exception ex) { result = ex.Message; resultOk = false; }
        finally { busy = false; }
    });

    private async Task GoBack() => await JS.InvokeVoidAsync("history.back");

    // ---- presentation helpers ----

    private string? LookupOwner(string name)
    {
        if (datasetsResult is null) return null;
        foreach (var row in datasetsResult.Rows)
            if (string.Equals(Cell(datasetsResult, row, "name"), name, StringComparison.OrdinalIgnoreCase))
            {
                var by = Cell(datasetsResult, row, "configuredBy");
                return string.IsNullOrEmpty(by) ? null : by;
            }
        return null;
    }

    /// <summary>Friendly label for the Fabric connectivityType enum.</summary>
    private static string Connectivity(string raw) => raw switch
    {
        "ShareableCloud" => "Cloud",
        "Automatic" => "Cloud (automatic)",
        "PersonalCloud" => "Personal cloud",
        "VirtualNetworkGateway" => "VNet gateway",
        "OnPremisesGateway" => "On-prem gateway",
        "OnPremisesGatewayPersonal" => "Personal gateway",
        "" or "None" => "—",
        _ => raw,
    };

    /// <summary>What a source currently maps to (connectivity → connection name), from the Fabric read.</summary>
    private static string CurrentMap(BindSource src)
        => string.IsNullOrEmpty(src.Connectivity) ? "—" : $"{Connectivity(src.Connectivity)} → {src.Name}";

    private string SourceLabel(object?[] row)
    {
        var type = Cell(datasources!, row, "datasourceType");
        var server = Cell(datasources!, row, "server");
        var db = Cell(datasources!, row, "database");
        var pathOrUrl = Cell(datasources!, row, "path");
        if (string.IsNullOrEmpty(pathOrUrl)) pathOrUrl = Cell(datasources!, row, "url");
        var detail = !string.IsNullOrEmpty(server)
            ? (string.IsNullOrEmpty(db) ? server : $"{server} / {db}")
            : pathOrUrl;
        return string.IsNullOrEmpty(detail) ? type : $"{type} — {detail}";
    }

    /// <summary>The model's sources unified for matching. Prefers the Fabric read (connection name +
    /// connectivity); falls back to the raw data sources when the Fabric API is unavailable.</summary>
    private List<BindSource> BuildBindSources()
    {
        var list = new List<BindSource>();
        if (itemConns is not null && itemConns.RowCount > 0)
        {
            foreach (var r in itemConns.Rows)
            {
                var name = Cell(itemConns, r, "displayName");
                var type = Cell(itemConns, r, "type");
                var (srv, db) = SplitPath(Cell(itemConns, r, "path"));
                var conn = Cell(itemConns, r, "connectivityType");
                var label = string.IsNullOrEmpty(srv) ? type : $"{type} — {srv}{(string.IsNullOrEmpty(db) ? "" : $" / {db}")}";
                list.Add(new BindSource(label, name, type, srv, db, conn));
            }
        }
        else if (datasources is not null)
        {
            foreach (var r in datasources.Rows)
                list.Add(new BindSource(SourceLabel(r), "", Cell(datasources, r, "datasourceType"),
                    Cell(datasources, r, "server"), Cell(datasources, r, "database"), ""));
        }
        return list;
    }

    /// <summary>Pre-select each source's current cloud connection in the Cloud section (display-only).</summary>
    private void BuildCloudPicks()
    {
        cloudPick.Clear();
        if (cloudConns is null) return;
        for (var i = 0; i < bindSources.Count; i++)
        {
            var src = bindSources[i];
            if (!src.Connectivity.StartsWith("Shareable", StringComparison.OrdinalIgnoreCase)
                && !src.Connectivity.Equals("Automatic", StringComparison.OrdinalIgnoreCase)
                && !src.Connectivity.Equals("PersonalCloud", StringComparison.OrdinalIgnoreCase))
                continue;   // only cloud sources have a current cloud mapping
            var match = MatchCloudConns(src).FirstOrDefault(c =>
                string.Equals(Cell(cloudConns, c, "displayName"), src.Name, StringComparison.OrdinalIgnoreCase));
            if (match is not null) cloudPick[i] = Cell(cloudConns, match, "id");
        }
    }

    /// <summary>Split a Fabric connection path ("server;database") into its two parts.</summary>
    private static (string Server, string Db) SplitPath(string path)
    {
        if (string.IsNullOrEmpty(path)) return ("", "");
        var i = path.IndexOf(';');
        return i < 0 ? (path, "") : (path[..i], path[(i + 1)..]);
    }

    /// <summary>Gateway connections matching a source — by connection <em>name</em> (reliable; the gateway
    /// endpoint often returns null server/database), falling back to type + server + database.</summary>
    private List<object?[]> MatchGwConns(QueryResult conns, BindSource src)
    {
        string Norm(string s) => s.Trim().ToLowerInvariant();
        var name = Norm(src.Name);
        var type = Norm(src.Type);
        var server = Norm(src.Server);
        var db = Norm(src.Db);
        bool Matches(object?[] g)
        {
            var gn = Norm(Cell(conns, g, "datasourceName"));
            var gt = Norm(Cell(conns, g, "datasourceType"));
            var gs = Norm(Cell(conns, g, "server"));
            var gd = Norm(Cell(conns, g, "database"));
            if (name.Length > 0 && gn.Length > 0 && gn == name) return true;
            if (server.Length > 0 && gs.Length > 0)
            {
                if (gt.Length > 0 && type.Length > 0 && gt != type) return false;
                if (gs != server) return false;
                if (db.Length > 0 && gd.Length > 0 && gd != db) return false;
                return true;
            }
            return false;
        }
        return conns.Rows.Where(Matches).ToList();
    }

    /// <summary>Shareable cloud connections matching a source — by name, or by type + server/database
    /// parsed from the connection path.</summary>
    private List<object?[]> MatchCloudConns(BindSource src)
    {
        if (cloudConns is null) return new();
        string Norm(string s) => s.Trim().ToLowerInvariant();
        var name = Norm(src.Name);
        var type = Norm(src.Type);
        var server = Norm(src.Server);
        var db = Norm(src.Db);
        bool Matches(object?[] c)
        {
            if (!string.Equals(Cell(cloudConns, c, "connectivityType"), "ShareableCloud", StringComparison.OrdinalIgnoreCase))
                return false;
            var cn = Norm(Cell(cloudConns, c, "displayName"));
            var ct = Norm(Cell(cloudConns, c, "type"));
            var (cs0, cd0) = SplitPath(Cell(cloudConns, c, "path"));
            var cs = Norm(cs0);
            var cd = Norm(cd0);
            if (name.Length > 0 && cn == name) return true;
            if (server.Length > 0 && cs.Length > 0)
            {
                if (ct.Length > 0 && type.Length > 0 && ct != type) return false;
                if (cs != server) return false;
                if (db.Length > 0 && cd.Length > 0 && cd != db) return false;
                return true;
            }
            return false;
        }
        return cloudConns.Rows.Where(Matches).ToList();
    }

    private static string GwConnLabel(QueryResult r, object?[] g)
    {
        var name = Cell(r, g, "datasourceName");
        var type = Cell(r, g, "datasourceType");
        var server = Cell(r, g, "server");
        var db = Cell(r, g, "database");
        var detail = string.IsNullOrEmpty(server) ? type : (string.IsNullOrEmpty(db) ? server : $"{server}/{db}");
        return string.IsNullOrEmpty(name) ? detail : $"{name} — {detail}";
    }

    private static string CloudConnLabel(QueryResult r, object?[] c)
    {
        var name = Cell(r, c, "displayName");
        var type = Cell(r, c, "type");
        return string.IsNullOrEmpty(type) ? name : $"{name} — {type}";
    }

    private static List<string> Names(QueryResult r)
    {
        var idx = 0;
        for (var i = 0; i < r.Columns.Count; i++)
            if (string.Equals(r.Columns[i], "Name", StringComparison.OrdinalIgnoreCase)) { idx = i; break; }
        return r.Rows.Select(row => idx < row.Length ? row[idx]?.ToString() ?? "" : "")
            .Where(s => s.Length > 0)
            .OrderBy(s => s, StringComparer.OrdinalIgnoreCase)   // picker lists are sorted A→Z
            .ToList();
    }

    private static string Cell(QueryResult r, object?[] row, string col)
    {
        for (var i = 0; i < r.Columns.Count; i++)
            if (string.Equals(r.Columns[i], col, StringComparison.OrdinalIgnoreCase))
                return i < row.Length ? row[i]?.ToString() ?? "" : "";
        return "";
    }
}
