# DAXter configuration — copy to .env and fill in. NEVER commit the real .env.

# --- Connection (required) ---
DAXTER_WORKSPACE=My Premium Workspace
# Optional: target a specific semantic model (Initial Catalog)
DAXTER_DATASET=My Dataset

# --- Environment profiles (optional): one SP, workspace per env ---
# Select with --env <name> or DAXTER_ENV; falls back to DAXTER_WORKSPACE above.
# DAXTER_ENV=dev
# DAXTER_WORKSPACE_DEV=Sales Analytics - Dev
# DAXTER_DATASET_DEV=Retail Model
# DAXTER_WORKSPACE_QA=Sales Analytics - QA
# DAXTER_WORKSPACE_PROD=Sales Analytics - Prod

# --- Auth mode: device-code (default, interactive) or service-principal ---
DAXTER_AUTH_MODE=device-code

# --- Entra ID (tenant is optional for device-code, required for service principal) ---
DAXTER_TENANT_ID=00000000-0000-0000-0000-000000000000
# Public client app registration id (device-code). Falls back to a default if unset.
DAXTER_CLIENT_ID=

# --- Service principal only (leave blank for device-code) ---
# DAXTER_AUTH_MODE=service-principal
# DAXTER_CLIENT_ID=<app-registration-client-id>
# DAXTER_CLIENT_SECRET=<app-secret>
